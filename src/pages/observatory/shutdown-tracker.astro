---
import Observatory from '../../layouts/Observatory.astro'
import CfRadarBanner from '../../components/CfRadarBanner.astro'
import stats from '../../content/observatory/stats.json'
import history from '../../data/ooni-history.json'
import historyWeekly from '../../data/ooni-history-weekly.json'
import historyDaily from '../../data/ooni-history-daily.json'
import cfOutages from '../../data/cf-radar-outages.json'
import cfTraffic from '../../data/cf-traffic.json'

export const prerender = false

// Narrative events with contextual labels — merged with actual anomaly data from history
const narrativeEvents: Record<string, string> = {
  '2021-02': 'Military coup — mass shutdowns begin',
  '2021-03': 'Social media blocked (Facebook, Twitter, Instagram)',
  '2021-07': 'Nightly internet curfews imposed (1–9 AM)',
  '2022-02': 'Coup anniversary — major network outage',
  '2022-09': 'Arakan Army offensive — regional blackouts',
  '2023-01': 'Telenor sold to military-linked KBZMS, General License revoked',
  '2023-10': 'Three Brotherhood Alliance offensive — Shan State blackouts',
  '2024-04': 'Operation 1027 fallout — Mandalay region disruptions',
  '2024-05': 'Escalating restrictions in conflict zones',
}

// Build enriched key events: narrative events augmented with measured anomaly rate
const historyMap = Object.fromEntries(history.map(r => [r.month, r]))
const keyEvents = Object.entries(narrativeEvents)
  .map(([date, label]) => ({
    date,
    label,
    rate: historyMap[date]?.anomaly_rate ?? null,
    anomalies: historyMap[date]?.anomaly_count ?? null,
  }))
  .sort((a, b) => a.date.localeCompare(b.date))

const totalMeasurements = history.reduce((s, r) => s + r.measurement_count, 0)

// CF monthly traffic lookup for the table
const cfMonthlyMap = Object.fromEntries(
  (cfTraffic.monthly || []).map((p: {month: string, cf_traffic: number}) => [p.month, p.cf_traffic])
)
---
<Observatory
  title="Myanmar Internet Shutdown Tracker"
  seoTitle="Myanmar Shutdown Tracker | Internet in Myanmar"
  metaDescription="Documented timeline of internet shutdowns and service disruptions in Myanmar since the 2021 military coup."
  lastUpdated={stats.lastUpdated}
  datasetName="Myanmar Internet Shutdown Timeline"
  datasetDescription="Documented timeline of internet shutdowns and service disruptions in Myanmar since the 2021 military coup, sourced from OONI, NetBlocks, and Cloudflare Radar."
  pageUrl="https://www.internetinmyanmar.com/observatory/shutdown-tracker/"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Shutdown Tracker</h1>
    <p class="opacity-70 mb-8 max-w-2xl">
      Documented shutdowns sourced from OONI measurements, NetBlocks, and Cloudflare Radar.
      The Myanmar military junta has used internet shutdowns as a tool of political repression since the February 2021 coup.
    </p>

    <div class="border border-[color:var(--color-warning)]/40 bg-[color:var(--color-warning)]/5 rounded-lg p-6 mb-6">
      <div class="font-mono text-xs text-[color:var(--color-warning)] mb-2 uppercase tracking-widest">Current status</div>
      {stats.activeShutdowns > 0
        ? <div class="text-2xl font-bold mb-1 text-[color:var(--color-danger)]">{stats.activeShutdowns} active shutdown{stats.activeShutdowns !== 1 ? 's' : ''} detected</div>
        : <div class="text-2xl font-bold mb-1 opacity-70">No active shutdowns detected</div>
      }
      <div class="text-sm opacity-60">
        As of {new Date(stats.lastUpdated).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
        · {stats.rawAnomaliesLast24h} anomal{stats.rawAnomaliesLast24h !== 1 ? 'ies' : 'y'} in last 24h across {stats.totalMeasurementsScanned} measurements
      </div>
    </div>

    <CfRadarBanner
      activeOutages={cfOutages.activeOutages}
      lastUpdated={cfOutages.lastUpdated}
    />

    <!-- Chart: scale toggles + Chart.js mixed bar+line -->
    <div class="mb-10">
      <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
        <div>
          <h2 class="font-headline text-xl">OONI Anomaly Rate + CF Traffic Volume</h2>
          <p class="text-xs opacity-40 font-mono mt-0.5">
            Bars = OONI anomaly % · Teal line = CF Radar traffic (100% = peak, last 12 months)
          </p>
        </div>
        <div class="flex gap-1 font-mono text-xs">
          <button class="scale-btn px-3 py-1.5 rounded border transition-colors" data-scale="monthly">5Y · monthly</button>
          <button class="scale-btn px-3 py-1.5 rounded border border-white/10 transition-colors" data-scale="weekly">1Y · weekly</button>
          <button class="scale-btn px-3 py-1.5 rounded border border-white/10 transition-colors" data-scale="daily">1M · daily</button>
        </div>
      </div>
      <div class="border border-white/10 rounded-lg p-4">
        <canvas id="ooni-chart" style="width:100%;height:220px"></canvas>
      </div>
      <div class="text-xs font-mono opacity-30 mt-2 flex flex-wrap gap-x-3">
        <span>OONI: <a href="https://api.ooni.io" target="_blank" rel="noopener" class="hover:opacity-100 underline">api.ooni.io</a> · {history.length} months · {totalMeasurements.toLocaleString()} measurements</span>
        <span>CF Radar: traffic volume normalised · CC BY-NC 4.0</span>
      </div>
    </div>

    <div class="mb-10">
      <h2 class="font-headline text-xl mb-4">Key Events</h2>
      <div class="space-y-0">
        {keyEvents.map((event) => (
          <div class="flex gap-4 items-start border-l-2 border-[color:var(--color-warning)]/30 pl-4 pb-6 relative">
            <div class="absolute -left-[5px] top-0 w-2 h-2 rounded-full bg-[color:var(--color-warning)]"></div>
            <div class="font-mono text-xs text-[color:var(--color-warning)] mt-0.5 whitespace-nowrap min-w-[4rem]">{event.date}</div>
            <div>
              <div class="text-sm">{event.label}</div>
              {event.rate !== null && (
                <div class="font-mono text-xs mt-0.5 opacity-50">
                  {event.rate}% anomaly rate · {(event.anomalies ?? 0).toLocaleString()} anomalies measured
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div>
      <h2 class="font-headline text-xl mb-4">Recent Monthly Measurements</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm font-mono">
          <thead>
            <tr class="text-left">
              <th class="pb-1 pr-6"></th>
              <th colspan="4" class="pb-1 pr-2 text-xs text-[color:var(--color-warning)] opacity-70 font-mono tracking-wider">OONI</th>
              <th class="pb-1 text-xs text-[color:var(--color-accent)] opacity-70 font-mono tracking-wider text-right">Cloudflare Radar</th>
            </tr>
            <tr class="border-b border-white/10 text-left opacity-50">
              <th class="pb-2 pr-6">Month</th>
              <th class="pb-2 pr-6 text-right">Measurements</th>
              <th class="pb-2 pr-6 text-right">Anomalies</th>
              <th class="pb-2 pr-6 text-right">Confirmed</th>
              <th class="pb-2 pr-6 text-right">Anomaly Rate</th>
              <th class="pb-2 text-right">Traffic Level</th>
            </tr>
          </thead>
          <tbody>
            {[...history].reverse().slice(0, 12).map((row) => (
              <tr class="border-b border-white/5 hover:bg-white/2">
                <td class="py-2 pr-6">{row.month}</td>
                <td class="py-2 pr-6 text-right opacity-60">{row.measurement_count.toLocaleString()}</td>
                <td class="py-2 pr-6 text-right" style={row.anomaly_rate > 20 ? 'color:var(--color-danger)' : row.anomaly_rate > 10 ? 'color:var(--color-warning)' : ''}>
                  {row.anomaly_count.toLocaleString()}
                </td>
                <td class="py-2 pr-6 text-right opacity-60">{row.confirmed_count.toLocaleString()}</td>
                <td class="py-2 pr-6 text-right" style={row.anomaly_rate > 20 ? 'color:var(--color-danger)' : row.anomaly_rate > 10 ? 'color:var(--color-warning)' : ''}>
                  {row.anomaly_rate}%
                </td>
                <td class="py-2 text-right" style="color:var(--color-accent)">
                  {cfMonthlyMap[row.month] != null
                    ? `${cfMonthlyMap[row.month]}%`
                    : <span class="opacity-20">—</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script define:vars={{
    ooniMonthly:  history,
    ooniWeekly:   historyWeekly,
    ooniDaily:    historyDaily,
    cfMonthly:    cfTraffic.monthly,
    cfWeekly:     cfTraffic.weekly,
    cfDaily:      cfTraffic.daily,
  }}>
    let chart       = null
    let activeScale = 'monthly'

    function buildDatasets(scale) {
      const ooni = { monthly: ooniMonthly, weekly: ooniWeekly, daily: ooniDaily }[scale] || []
      const cf   = { monthly: cfMonthly,   weekly: cfWeekly,   daily: cfDaily   }[scale] || []

      if (!ooni.length) return { labels: [], datasets: [] }

      const labels = ooni.map(d => {
        const p = d.period || d.month || d.measurement_start_day || ''
        if (scale === 'monthly') return p.slice(0, 7)
        try { return new Date(p).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) }
        catch { return p.slice(5, 10) }
      })

      const barColors = ooni.map(d =>
        d.anomaly_rate > 30 ? '#EF4444cc'
        : d.anomaly_rate > 15 ? '#F59E0Bcc'
        : '#7170ff99'
      )

      const datasets = [{
        type: 'bar',
        label: 'OONI Anomaly Rate (%)',
        data: ooni.map(d => d.anomaly_rate),
        backgroundColor: barColors,
        borderRadius: 2,
        yAxisID: 'yOoni',
      }]

      if (cf && cf.length > 0) {
        const cfMap = {}
        cf.forEach(p => {
          let raw = (p.timestamp || p.week || p.date || p.month || '')
          let key
          if (scale === 'monthly') {
            key = raw.slice(0, 7)
          } else if (scale === 'weekly' && p.timestamp) {
            // CF Radar weeks start Monday; OONI weeks start Sunday — shift back 1 day
            const d = new Date(p.timestamp)
            d.setUTCDate(d.getUTCDate() - 1)
            key = d.toISOString().slice(0, 10)
          } else {
            key = raw.slice(0, 10)
          }
          cfMap[key] = p.cf_traffic
        })
        const cfData = ooni.map(d => {
          const key = (d.period || d.month || d.measurement_start_day || '').slice(0, scale === 'monthly' ? 7 : 10)
          return cfMap[key] != null ? cfMap[key] : null
        })
        datasets.push({
          type: 'line',
          label: 'CF Traffic (% of peak)',
          data: cfData,
          borderColor: '#00D4C8',
          backgroundColor: 'transparent',
          borderWidth: 1.5,
          pointRadius: 0,
          spanGaps: true,
          tension: 0.3,
          yAxisID: 'yCf',
        })
      }

      return { labels, datasets }
    }

    function renderChart() {
      const canvas = document.getElementById('ooni-chart')
      if (!canvas) return
      const ctx = canvas.getContext('2d')
      if (!ctx) return
      if (chart) chart.destroy()
      const { labels, datasets } = buildDatasets(activeScale)

      if (!labels.length) {
        canvas.parentElement.innerHTML = '<p style="opacity:.4;font-size:.75rem;padding:1rem;font-family:monospace">No data for this range yet — agent runs at 8 AM and 8 PM UTC.</p>'
        return
      }

      chart = new window.Chart(ctx, {
        data: { labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              display: true,
              labels: { color: '#94a3b8', font: { size: 10, family: 'monospace' }, boxWidth: 12, padding: 16 }
            },
            tooltip: {
              backgroundColor: '#0f1f3a',
              titleColor: '#94a3b8',
              bodyColor: '#e2e8f0',
              callbacks: {
                label: c => c.dataset.label.startsWith('OONI')
                  ? ` OONI: ${c.parsed.y}% anomaly rate`
                  : ` CF Traffic: ${c.parsed.y}% of peak`
              }
            }
          },
          scales: {
            x: {
              ticks: { color: '#64748b', font: { size: 9 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 24 },
              grid:  { color: 'rgba(255,255,255,0.04)' }
            },
            yOoni: {
              position: 'left',
              beginAtZero: true,
              max: 100,
              ticks: { color: '#64748b', font: { size: 9 }, callback: v => `${v}%` },
              grid:  { color: 'rgba(255,255,255,0.04)' },
              title: { display: true, text: 'Anomaly %', color: '#64748b', font: { size: 9 } }
            },
            yCf: {
              position: 'right',
              beginAtZero: true,
              max: 100,
              ticks: { color: '#00D4C8', font: { size: 9 }, callback: v => `${v}%` },
              grid:  { display: false },
              title: { display: true, text: 'CF Traffic %', color: '#00D4C8', font: { size: 9 } }
            },
          }
        }
      })
    }

    function setActiveScale(scale) {
      activeScale = scale
      document.querySelectorAll('.scale-btn').forEach(btn => {
        const isActive = btn.dataset.scale === scale
        btn.style.borderColor = isActive ? 'var(--color-accent)' : 'rgba(255,255,255,0.1)'
        btn.style.color       = isActive ? 'var(--color-accent)' : ''
      })
      renderChart()
    }

    // Trigger initial active style on monthly button
    function initButtons() {
      setActiveScale('monthly')
    }

    const s = document.createElement('script')
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js'
    s.onload = () => {
      initButtons()
      document.querySelectorAll('.scale-btn').forEach(btn =>
        btn.addEventListener('click', () => setActiveScale(btn.dataset.scale))
      )
    }
    document.head.appendChild(s)
  </script>
</Observatory>
