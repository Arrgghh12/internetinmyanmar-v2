---
import Observatory from '../../layouts/Observatory.astro'
import CfRadarBanner from '../../components/CfRadarBanner.astro'
import stats from '../../content/observatory/stats.json'
import history from '../../data/ooni-history.json'
import historyWeekly from '../../data/ooni-history-weekly.json'
import historyDaily from '../../data/ooni-history-daily.json'
import cfOutages from '../../data/cf-radar-outages.json'
import cfTraffic from '../../data/cf-traffic.json'
import OoniBreakdownChart from '../../components/charts/OoniBreakdownChart.astro'
import keepitonData from '../../data/keepiton-shutdowns.json'

const TYPE_LABELS: Record<string, string> = {
  full_network: 'Full network',
  mobile:       'Mobile',
  platform:     'Platform',
  throttle:     'Throttle',
}
const TYPE_COLORS: Record<string, string> = {
  full_network: 'var(--color-danger)',
  mobile:       'var(--color-warning)',
  platform:     '#a78bfa',
  throttle:     '#64748b',
}

export const prerender = false

// Narrative events with contextual labels — merged with actual anomaly data from history
const narrativeEvents: Record<string, string> = {
  '2021-02': 'Military coup — mass shutdowns begin',
  '2021-03': 'Social media blocked (Facebook, Twitter, Instagram)',
  '2021-07': 'Nightly internet curfews imposed (1–9 AM)',
  '2022-02': 'Coup anniversary — major network outage',
  '2022-09': 'Arakan Army offensive — regional blackouts',
  '2023-01': 'Telenor sold to military-linked KBZMS, General License revoked',
  '2023-10': 'Three Brotherhood Alliance offensive — Shan State blackouts',
  '2024-04': 'Operation 1027 fallout — Mandalay region disruptions',
  '2024-05': 'Escalating restrictions in conflict zones',
}

// Build enriched key events: narrative events augmented with measured anomaly rate
const historyMap = Object.fromEntries(history.map(r => [r.month, r]))
const keyEvents = Object.entries(narrativeEvents)
  .map(([date, label]) => ({
    date,
    label,
    rate: historyMap[date]?.anomaly_rate ?? null,
    anomalies: historyMap[date]?.anomaly_count ?? null,
  }))
  .sort((a, b) => a.date.localeCompare(b.date))

const totalMeasurements = history.reduce((s, r) => s + r.measurement_count, 0)

// CF monthly traffic lookup for the table
const cfMonthlyMap = Object.fromEntries(
  (cfTraffic.monthly || []).map((p: {month: string, cf_traffic: number}) => [p.month, p.cf_traffic])
)
---
<Observatory
  title="Myanmar Internet Shutdown Tracker"
  seoTitle="Myanmar Shutdown Tracker | Internet in Myanmar"
  metaDescription="Documented timeline of internet shutdowns and service disruptions in Myanmar since the 2021 military coup."
  lastUpdated={stats.lastUpdated}
  datasetName="Myanmar Internet Shutdown Timeline"
  datasetDescription="Documented timeline of internet shutdowns and service disruptions in Myanmar since the 2021 military coup, sourced from OONI, NetBlocks, and Cloudflare Radar."
  pageUrl="https://www.internetinmyanmar.com/observatory/shutdown-tracker/"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Shutdown Tracker</h1>
    <p class="opacity-70 mb-8 max-w-2xl">
      Documented shutdowns sourced from OONI measurements, NetBlocks, and Cloudflare Radar.
      The Myanmar military junta has used internet shutdowns as a tool of political repression since the February 2021 coup.
    </p>

    <div class="border border-[color:var(--color-warning)]/40 bg-[color:var(--color-warning)]/5 rounded-lg p-6 mb-6">
      <div class="font-mono text-xs text-[color:var(--color-warning)] mb-2 uppercase tracking-widest">Current status</div>
      {stats.activeShutdowns > 0
        ? <div class="text-2xl font-bold mb-1 text-[color:var(--color-danger)]">{stats.activeShutdowns} active shutdown{stats.activeShutdowns !== 1 ? 's' : ''} detected</div>
        : <div class="text-2xl font-bold mb-1 opacity-70">No active shutdowns detected</div>
      }
      <div class="text-sm opacity-60">
        As of {new Date(stats.lastUpdated).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
        · {stats.rawAnomaliesLast24h} anomal{stats.rawAnomaliesLast24h !== 1 ? 'ies' : 'y'} in last 24h across {stats.totalMeasurementsScanned} measurements
      </div>
    </div>

    <CfRadarBanner
      activeOutages={cfOutages.activeOutages}
      lastUpdated={cfOutages.lastUpdated}
    />

    <!-- Chart: scale toggles + Chart.js mixed bar+line -->
    <div class="mb-10">
      <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
        <div>
          <h2 class="font-headline text-xl">OONI Anomaly Rate + CF Traffic Volume</h2>
          <p class="text-xs opacity-40 font-mono mt-0.5">
            Bars = OONI anomaly % · Teal line = CF Radar traffic (100% = peak, last 12 months)
          </p>
        </div>
        <div class="flex gap-1 font-mono text-xs">
          <button class="scale-btn px-3 py-1.5 rounded border transition-colors" data-scale="monthly">5Y · monthly</button>
          <button class="scale-btn px-3 py-1.5 rounded border border-white/10 transition-colors" data-scale="weekly">1Y · weekly</button>
          <button class="scale-btn px-3 py-1.5 rounded border border-white/10 transition-colors" data-scale="daily">1M · daily</button>
        </div>
      </div>
      <div class="border border-white/10 rounded-lg p-4">
        <canvas id="ooni-chart" style="width:100%;height:220px"></canvas>
      </div>
      <div class="text-xs font-mono opacity-30 mt-2 flex flex-wrap gap-x-3">
        <span>OONI: <a href="https://api.ooni.io" target="_blank" rel="noopener" class="hover:opacity-100 underline">api.ooni.io</a> · {history.length} months · {totalMeasurements.toLocaleString()} measurements</span>
        <span>CF Radar: traffic volume normalised · CC BY-NC 4.0</span>
      </div>
    </div>

    <div class="mb-10">
      <h2 class="font-headline text-xl mb-4">Key Events</h2>
      <div class="space-y-0">
        {keyEvents.map((event) => (
          <div class="flex gap-4 items-start border-l-2 border-[color:var(--color-warning)]/30 pl-4 pb-6 relative">
            <div class="absolute -left-[5px] top-0 w-2 h-2 rounded-full bg-[color:var(--color-warning)]"></div>
            <div class="font-mono text-xs text-[color:var(--color-warning)] mt-0.5 whitespace-nowrap min-w-[4rem]">{event.date}</div>
            <div>
              <div class="text-sm">{event.label}</div>
              {event.rate !== null && (
                <div class="font-mono text-xs mt-0.5 opacity-50">
                  {event.rate}% anomaly rate · {(event.anomalies ?? 0).toLocaleString()} anomalies measured
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- KeepItOn verified shutdowns list -->
    {keepitonData.events.length > 0 && (
      <div class="mb-10">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <div>
            <h2 class="font-headline text-xl">Verified Shutdowns</h2>
            <p class="text-xs font-mono opacity-40 mt-0.5">
              Access Now STOP Dataset · human-verified events · {keepitonData.totalEvents} Myanmar records
            </p>
          </div>
          <a href="/data/keepiton-shutdowns.json" class="text-xs font-mono opacity-40 hover:opacity-70 transition-opacity">↓ download JSON</a>
        </div>

        <div class="space-y-0 border border-white/10 rounded-lg overflow-hidden">
          {[...keepitonData.events].reverse().map(ev => (
            <div class="flex flex-wrap gap-3 items-start px-4 py-3 border-b border-white/5 last:border-0 hover:bg-white/2">
              <!-- Type badge -->
              <span class="inline-block font-mono text-xs px-2 py-0.5 rounded-full border flex-shrink-0 mt-0.5"
                style={`color:${TYPE_COLORS[ev.type] ?? '#fff'};border-color:${TYPE_COLORS[ev.type] ?? '#fff'}40`}>
                {TYPE_LABELS[ev.type] ?? ev.type}
              </span>
              <!-- Date range -->
              <span class="font-mono text-xs opacity-70 flex-shrink-0 mt-0.5">
                {ev.startDate} → {ev.ongoing ? 'present' : (ev.endDate ?? '?')}
              </span>
              <!-- Scope + perpetrator -->
              <span class="text-sm opacity-80 flex-1 min-w-0">
                {ev.scope}{ev.perpetrator ? ` · ${ev.perpetrator}` : ''}
              </span>
              <!-- Source link -->
              {ev.sourceUrl && (
                <a href={ev.sourceUrl} target="_blank" rel="noopener noreferrer"
                  class="font-mono text-xs text-[color:var(--color-accent)] opacity-50 hover:opacity-100 flex-shrink-0 mt-0.5">
                  source →
                </a>
              )}
            </div>
          ))}
        </div>

        <p class="text-xs font-mono opacity-25 mt-2">
          Source: <a href="https://www.accessnow.org/keepiton/" target="_blank" rel="noopener" class="underline hover:opacity-60">Access Now STOP Dataset</a>
          · verified by Access Now researchers · updated weekly ·
          <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener" class="underline hover:opacity-60">CC BY 4.0</a>
        </p>
      </div>
    )}

    <OoniBreakdownChart />

    <div>
      <h2 class="font-headline text-xl mb-4">Recent Monthly Measurements</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm font-mono">
          <thead>
            <tr class="text-left">
              <th class="pb-1 pr-6"></th>
              <th colspan="4" class="pb-1 pr-2 text-xs text-[color:var(--color-warning)] opacity-70 font-mono tracking-wider">OONI</th>
              <th class="pb-1 text-xs text-[color:var(--color-accent)] opacity-70 font-mono tracking-wider text-right">Cloudflare Radar</th>
            </tr>
            <tr class="border-b border-white/10 text-left opacity-50">
              <th class="pb-2 pr-6">Month</th>
              <th class="pb-2 pr-6 text-right">Measurements</th>
              <th class="pb-2 pr-6 text-right">Anomalies</th>
              <th class="pb-2 pr-6 text-right">Confirmed</th>
              <th class="pb-2 pr-6 text-right">Anomaly Rate</th>
              <th class="pb-2 text-right">Traffic Level</th>
            </tr>
          </thead>
          <tbody>
            {[...history].reverse().slice(0, 12).map((row) => (
              <tr class="border-b border-white/5 hover:bg-white/2">
                <td class="py-2 pr-6">{row.month}</td>
                <td class="py-2 pr-6 text-right opacity-60">{row.measurement_count.toLocaleString()}</td>
                <td class="py-2 pr-6 text-right" style={row.anomaly_rate > 20 ? 'color:var(--color-danger)' : row.anomaly_rate > 10 ? 'color:var(--color-warning)' : ''}>
                  {row.anomaly_count.toLocaleString()}
                </td>
                <td class="py-2 pr-6 text-right opacity-60">{row.confirmed_count.toLocaleString()}</td>
                <td class="py-2 pr-6 text-right" style={row.anomaly_rate > 20 ? 'color:var(--color-danger)' : row.anomaly_rate > 10 ? 'color:var(--color-warning)' : ''}>
                  {row.anomaly_rate}%
                </td>
                <td class="py-2 text-right" style="color:var(--color-accent)">
                  {cfMonthlyMap[row.month] != null
                    ? `${cfMonthlyMap[row.month]}%`
                    : <span class="opacity-20">—</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-16 border-t border-white/10 pt-10 max-w-3xl">
      <h2 class="font-headline text-xl mb-6">Measurement Methodology</h2>

      <div class="space-y-5 text-sm leading-relaxed opacity-80">
        <p>
          This tracker draws on three independent data pipelines — OONI Web Connectivity measurements,
          Cloudflare Radar traffic telemetry, and BGP routing surveillance — cross-corroborated in
          near real-time to document network interference and internet shutdowns affecting Myanmar.
          No single source is treated as definitive; events are classified only when multiple signals
          converge across independent measurement infrastructures.
        </p>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-warning)] uppercase tracking-widest mb-2">OONI Web Connectivity</h3>
          <p>
            The primary signal comes from the <a href="https://ooni.org" target="_blank" rel="noopener" class="underline hover:opacity-100">Open Observatory of Network Interference (OONI)</a>,
            a global passive measurement platform that probes web connectivity from volunteer-operated
            vantage points inside Myanmar. OONI's Web Connectivity test fetches a curated list of URLs
            from within the country and compares results against a control measurement taken outside
            Myanmar. Discrepancies — including DNS lookup failures, TCP/IP connection resets, and
            HTTP-level blocking consistent with transparent proxying — are classified as anomalies.
            When anomalies are confirmed across multiple independent probes targeting the same URL or
            autonomous system, OONI records a confirmed blocking event. We aggregate this data at
            monthly, weekly, and daily granularity to surface both long-term structural censorship
            patterns and acute, time-bound shutdown events. The anomaly rate — the share of measurements
            returning an anomalous result in a given period — is our primary quantitative indicator
            of the severity and breadth of network interference in Myanmar.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs text-[color:var(--color-accent)] uppercase tracking-widest mb-2">Cloudflare Radar Traffic Overlay — Reading the Chart</h3>
          <p>
            OONI measurements capture application-layer interference but do not measure total
            traffic volume. The chart above overlays two independent signals simultaneously:
            purple/amber/red bars showing the OONI anomaly rate on the left axis, and a teal line
            showing
            <a href="https://radar.cloudflare.com" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">Cloudflare Radar</a>
            Myanmar IP traffic volume on the right axis, normalised to a 0–100 index where 100
            represents the historical peak for the period.
          </p>
          <p class="mt-3">
            The diagnostic power of this visualisation lies in the relationship between the two
            signals. A spike in OONI anomalies accompanied by a simultaneous drop in Cloudflare
            Radar traffic is the strongest available indicator of a broad, network-layer shutdown:
            censorship that is not merely blocking specific URLs but cutting off population-level
            internet access. Conversely, elevated OONI anomalies without a corresponding traffic
            drop typically indicate targeted content blocking — specific platforms or domains
            blacklisted while general internet connectivity remains available. This distinction
            matters critically for human rights documentation: a traffic drop correlated with an
            OONI anomaly spike constitutes strong technical evidence of a deliberate shutdown,
            suitable for citation in legal filings, UN reporting, and sanctions documentation in
            a way that anomaly data alone cannot.
          </p>
          <p class="mt-3">
            The three time scales — 5-year monthly, 1-year weekly, 1-month daily — are designed
            to reveal different phenomena. The 5-year monthly view shows the structural pattern
            of internet repression since the coup: the Cloudflare traffic baseline that was near
            zero in early 2021 has grown as Myanmar's internet penetration increased, making
            traffic drops in later years more visible against a higher baseline. The weekly and
            daily views reveal the operational tempo of censorship events — the timing of curfews,
            the hours when shutdowns are imposed and lifted, and the correlation with specific
            military offensives or protest events. This dual-signal, multi-scale approach mirrors
            methodologies used by
            <a href="https://netblocks.org" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">NetBlocks</a>
            and the <a href="https://ioda.inetintel.cc.gatech.edu" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-100">Internet Outage Detection and Analysis (IODA)</a>
            project at CAIDA. Routing-layer evidence for the same events is available on the
            <a href="/observatory/bgp/" class="underline hover:opacity-100">BGP Network Status</a> page.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs opacity-60 uppercase tracking-widest mb-2 font-mono">BGP Routing Surveillance</h3>
          <p>
            At the routing layer, we monitor Border Gateway Protocol (BGP) update activity for
            Myanmar's registered autonomous systems. Withdrawal of BGP prefixes — the routing
            announcements that make IP address blocks globally reachable — is a definitive technical
            signal of deliberate or accidental network disconnection. Our BGP monitoring pipeline
            scans critical Myanmar ASNs including MPT (AS9988), Mytel (AS136168), Ooredoo Myanmar
            (AS132748), and Atom Myanmar (AS132167) every five minutes, classifying routing events
            by severity and probable cause using a combination of rule-based heuristics and
            contextual analysis.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs opacity-60 uppercase tracking-widest mb-2 font-mono">Anomaly Classification & Thresholds</h3>
          <p>
            Anomaly rates above 20% in a measurement period are flagged as high-severity disruptions
            consistent with documented shutdown events. Rates between 10–20% are marked as elevated
            interference warranting contextual analysis against political and conflict timelines.
            Below 10%, measurements are treated as baseline noise absent corroborating signals.
            Classification of confirmed shutdowns is not automated: each event in the Key Events
            timeline has been manually verified against contemporaneous reporting from Fortify Rights,
            Free Expression Myanmar, the Irrawaddy, Democratic Voice of Burma, and international wire services.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs opacity-60 uppercase tracking-widest mb-2 font-mono">Limitations & Transparency</h3>
          <p>
            Passive measurement infrastructure carries inherent constraints. OONI coverage depends
            on the number and geographic distribution of active probes within Myanmar, which has
            declined since the 2021 military coup as digital security risks have increased for local
            researchers and civil society. Low probe density in conflict-affected regions — particularly
            Shan, Kachin, and Rakhine States — means localised shutdowns may be underrepresented in
            aggregate figures. Cloudflare Radar reflects traffic transiting Cloudflare's network,
            not total internet traffic; it functions as a robust proxy signal, not an absolute
            measure. OONI data is published under a <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener" class="underline hover:opacity-100">CC BY 4.0 licence</a>;
            Cloudflare Radar data under CC BY-NC 4.0. Our methodology, update cadence, and data
            pipeline are open for independent review and reproducibility.
          </p>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{
    ooniMonthly:    history,
    ooniWeekly:     historyWeekly,
    ooniDaily:      historyDaily,
    cfMonthly:      cfTraffic.monthly,
    cfWeekly:       cfTraffic.weekly,
    cfDaily:        cfTraffic.daily,
    keepitonEvents: keepitonData.events,
  }}>
    let chart       = null
    let activeScale = 'monthly'

    function buildDatasets(scale) {
      const ooni = { monthly: ooniMonthly, weekly: ooniWeekly, daily: ooniDaily }[scale] || []
      const cf   = { monthly: cfMonthly,   weekly: cfWeekly,   daily: cfDaily   }[scale] || []

      if (!ooni.length) return { labels: [], datasets: [] }

      const labels = ooni.map(d => {
        const p = d.period || d.month || d.measurement_start_day || ''
        if (scale === 'monthly') return p.slice(0, 7)
        try { return new Date(p).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) }
        catch { return p.slice(5, 10) }
      })

      const barColors = ooni.map(d =>
        d.anomaly_rate > 30 ? '#EF4444cc'
        : d.anomaly_rate > 15 ? '#F59E0Bcc'
        : '#7170ff99'
      )

      const datasets = [{
        type: 'bar',
        label: 'OONI Anomaly Rate (%)',
        data: ooni.map(d => d.anomaly_rate),
        backgroundColor: barColors,
        borderRadius: 2,
        yAxisID: 'yOoni',
      }]

      if (cf && cf.length > 0) {
        const cfMap = {}
        cf.forEach(p => {
          let raw = (p.timestamp || p.week || p.date || p.month || '')
          let key
          if (scale === 'monthly') {
            key = raw.slice(0, 7)
          } else if (scale === 'weekly' && p.timestamp) {
            // CF Radar weeks start Monday; OONI weeks start Sunday — shift back 1 day
            const d = new Date(p.timestamp)
            d.setUTCDate(d.getUTCDate() - 1)
            key = d.toISOString().slice(0, 10)
          } else {
            key = raw.slice(0, 10)
          }
          cfMap[key] = p.cf_traffic
        })
        const cfData = ooni.map(d => {
          const key = (d.period || d.month || d.measurement_start_day || '').slice(0, scale === 'monthly' ? 7 : 10)
          return cfMap[key] != null ? cfMap[key] : null
        })
        datasets.push({
          type: 'line',
          label: 'CF Traffic (% of peak)',
          data: cfData,
          borderColor: '#00D4C8',
          backgroundColor: 'transparent',
          borderWidth: 1.5,
          pointRadius: 0,
          spanGaps: true,
          tension: 0.3,
          yAxisID: 'yCf',
        })
      }

      return { labels, datasets }
    }

    function renderChart() {
      const canvas = document.getElementById('ooni-chart')
      if (!canvas) return
      const ctx = canvas.getContext('2d')
      if (!ctx) return
      if (chart) chart.destroy()
      const { labels, datasets } = buildDatasets(activeScale)

      if (!labels.length) {
        canvas.parentElement.innerHTML = '<p style="opacity:.4;font-size:.75rem;padding:1rem;font-family:monospace">No data for this range yet — agent runs at 8 AM and 8 PM UTC.</p>'
        return
      }

      const keepitonPlugin = {
        id: 'keepitonOverlay',
        afterDraw(ch) {
          if (!keepitonEvents || !keepitonEvents.length) return
          const meta = ch.getDatasetMeta(0)
          if (!meta || !meta.data.length) return
          const { ctx: c, scales: { yOoni } } = ch
          const ooni = { monthly: ooniMonthly, weekly: ooniWeekly, daily: ooniDaily }[activeScale] || []
          const periods = ooni.map(d => d.period || d.month || d.measurement_start_day || '')
          const today = new Date().toISOString().slice(0, 10)
          const typeColors = {
            full_network: { fill: 'rgba(239,68,68,0.12)',   border: 'rgba(239,68,68,0.65)'  },
            mobile:       { fill: 'rgba(245,158,11,0.10)',  border: 'rgba(245,158,11,0.55)' },
            platform:     { fill: 'rgba(139,92,246,0.10)',  border: 'rgba(139,92,246,0.55)' },
            throttle:     { fill: 'rgba(100,116,139,0.10)', border: 'rgba(100,116,139,0.5)' },
          }
          c.save()
          keepitonEvents.forEach(ev => {
            const s = activeScale === 'monthly' ? (ev.startDate || '').slice(0, 7) : (ev.startDate || '').slice(0, 10)
            const e = activeScale === 'monthly'
              ? (ev.ongoing ? today.slice(0, 7) : (ev.endDate || today).slice(0, 7))
              : (ev.ongoing ? today : (ev.endDate || today).slice(0, 10))
            if (!s) return
            let firstIdx = -1, lastIdx = -1
            periods.forEach((p, i) => {
              const pk = activeScale === 'monthly' ? p.slice(0, 7) : p.slice(0, 10)
              if (pk >= s && pk <= e) { if (firstIdx === -1) firstIdx = i; lastIdx = i }
            })
            if (firstIdx === -1) return
            const colors = typeColors[ev.type] || typeColors.full_network
            const bw = meta.data[firstIdx].width || 8
            const x1 = meta.data[firstIdx].x - bw / 2
            const x2 = meta.data[lastIdx].x  + bw / 2
            const top = yOoni.top, bottom = yOoni.bottom
            c.fillStyle = colors.fill
            c.fillRect(x1, top, x2 - x1, bottom - top)
            c.strokeStyle = colors.border
            c.lineWidth = 2
            c.setLineDash([])
            c.beginPath(); c.moveTo(x1, top); c.lineTo(x2, top); c.stroke()
          })
          c.restore()
        }
      }

      chart = new window.Chart(ctx, {
        plugins: [keepitonPlugin],
        data: { labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              display: true,
              labels: { color: '#94a3b8', font: { size: 10, family: 'monospace' }, boxWidth: 12, padding: 16 }
            },
            tooltip: {
              backgroundColor: '#0f1f3a',
              titleColor: '#94a3b8',
              bodyColor: '#e2e8f0',
              callbacks: {
                label: c => c.dataset.label.startsWith('OONI')
                  ? ` OONI: ${c.parsed.y}% anomaly rate`
                  : ` CF Traffic: ${c.parsed.y}% of peak`
              }
            }
          },
          scales: {
            x: {
              ticks: { color: '#64748b', font: { size: 9 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 24 },
              grid:  { color: 'rgba(255,255,255,0.04)' }
            },
            yOoni: {
              position: 'left',
              beginAtZero: true,
              max: 100,
              ticks: { color: '#64748b', font: { size: 9 }, callback: v => `${v}%` },
              grid:  { color: 'rgba(255,255,255,0.04)' },
              title: { display: true, text: 'Anomaly %', color: '#64748b', font: { size: 9 } }
            },
            yCf: {
              position: 'right',
              beginAtZero: true,
              max: 100,
              ticks: { color: '#00D4C8', font: { size: 9 }, callback: v => `${v}%` },
              grid:  { display: false },
              title: { display: true, text: 'CF Traffic %', color: '#00D4C8', font: { size: 9 } }
            },
          }
        }
      })
    }

    function setActiveScale(scale) {
      activeScale = scale
      document.querySelectorAll('.scale-btn').forEach(btn => {
        const isActive = btn.dataset.scale === scale
        btn.style.borderColor = isActive ? 'var(--color-accent)' : 'rgba(255,255,255,0.1)'
        btn.style.color       = isActive ? 'var(--color-accent)' : ''
      })
      renderChart()
    }

    // Trigger initial active style on monthly button
    function initButtons() {
      setActiveScale('monthly')
    }

    const s = document.createElement('script')
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js'
    s.onload = () => {
      initButtons()
      document.querySelectorAll('.scale-btn').forEach(btn =>
        btn.addEventListener('click', () => setActiveScale(btn.dataset.scale))
      )
    }
    document.head.appendChild(s)
  </script>
</Observatory>
