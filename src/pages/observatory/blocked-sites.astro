---
import Observatory from '../../layouts/Observatory.astro'
import stats from '../../content/observatory/stats.json'

export const prerender = false
---
<Observatory
  title="Blocked Sites Monitor — Myanmar"
  seoTitle="Myanmar Blocked Sites Monitor | Internet in Myanmar"
  metaDescription="Confirmed blocked domains across Myanmar ISPs. Updated from OONI measurement data."
  lastUpdated={stats.lastUpdated}
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Blocked Sites Monitor</h1>
    <p class="opacity-70 mb-8 max-w-2xl">
      Domains confirmed blocked across Myanmar ISPs based on OONI measurement data.
      A site is listed only when blocking is confirmed by multiple independent measurements.
    </p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-8">
      <div class="border border-white/10 rounded-lg p-4 text-center">
        <div class="font-mono text-2xl font-bold text-[color:var(--color-danger)]">{stats.blockedSites}</div>
        <div class="text-xs opacity-60 mt-1">Confirmed blocked</div>
      </div>
      <div class="border border-white/10 rounded-lg p-4 text-center">
        <div class="font-mono text-2xl font-bold text-[color:var(--color-warning)]">4</div>
        <div class="text-xs opacity-60 mt-1">ISPs monitored</div>
      </div>
      <div class="border border-white/10 rounded-lg p-4 text-center">
        <div class="font-mono text-2xl font-bold text-[color:var(--color-accent)]">MM</div>
        <div class="text-xs opacity-60 mt-1">Country</div>
      </div>
    </div>

    <div class="text-center py-16 border border-white/10 rounded-lg opacity-50">
      <div class="font-mono text-sm mb-2">Blocked sites database coming soon</div>
      <div class="text-xs">OONI watcher agent populates this automatically</div>
    </div>

    <div class="mt-8 text-xs font-mono opacity-40">
      Source: <a href="https://ooni.org/country/MM" target="_blank" rel="noopener" class="hover:opacity-100">OONI Explorer — Myanmar</a>
    </div>
  </div>
</Observatory>
