---
import Observatory from '../../layouts/Observatory.astro'
import { statSync, readFileSync } from 'fs'
import { resolve } from 'path'

export const prerender = true

function fileMtime(filename: string): string {
  try {
    const p = resolve('./public/data/', filename)
    const mtime = statSync(p).mtime
    return mtime.toISOString().slice(0, 16).replace('T', ' ') + ' UTC'
  } catch { return '' }
}

// metrics_snapshot.json has a precise generated_at field
function metricsUpdatedAt(): string {
  try {
    const raw = JSON.parse(readFileSync(resolve('./public/data/metrics_snapshot.json'), 'utf-8'))
    if (raw.generated_at) return raw.generated_at.slice(0, 16).replace('T', ' ') + ' UTC'
  } catch { /* fall through */ }
  return fileMtime('metrics_snapshot.json')
}

const datasets = [
  {
    file: 'unified_events.json',
    title: 'Unified Events',
    description: 'All BGP prefix withdrawal events and Access Now KeepItOn-verified shutdown events merged and cross-validated. The primary research dataset.',
    format: 'JSON',
    size: '~734 KB',
    license: 'CC BY 4.0',
    url: '/data/unified_events.json',
    updatedAt: fileMtime('unified_events.json'),
  },
  {
    file: 'bgp_events.csv',
    title: 'BGP Outage Events',
    description: 'BGP prefix withdrawal events across Myanmar autonomous systems, collected via the IIM BGP Observatory (active from April 2026). Includes ASN, duration, severity, and IODA cross-validation flag.',
    format: 'CSV',
    size: '~109 KB',
    license: 'CC BY 4.0',
    url: '/data/bgp_events.csv',
    updatedAt: fileMtime('bgp_events.csv'),
  },
  {
    file: 'keepiton_shutdowns.csv',
    title: 'Verified Shutdown Events',
    description: 'Access Now KeepItOn STOP Dataset events for Myanmar, normalized and enriched with region codes and affected population estimates.',
    format: 'CSV',
    size: '~23 KB',
    license: 'CC BY 4.0',
    url: '/data/keepiton_shutdowns.csv',
    updatedAt: fileMtime('keepiton_shutdowns.csv'),
  },
  {
    file: 'ooni_timeseries.csv',
    title: 'OONI Monthly Timeseries',
    description: 'Monthly OONI Web Connectivity anomaly rates for Myanmar, February 2021 to present. Includes measurement count, anomaly count, confirmed count, and anomaly rate percentage.',
    format: 'CSV',
    size: '~5 KB',
    license: 'CC BY 4.0',
    url: '/data/ooni_timeseries.csv',
    updatedAt: fileMtime('ooni_timeseries.csv'),
  },
  {
    file: 'blocked_sites.csv',
    title: 'Blocked Sites Database',
    description: 'Confirmed blocked domains across Myanmar ISPs with OONI anomaly rates, category classification, and measurement counts. Updated twice daily.',
    format: 'CSV',
    size: '~2 KB',
    license: 'CC BY 4.0',
    url: '/data/blocked_sites.csv',
    updatedAt: fileMtime('blocked_sites.csv'),
  },
  {
    file: 'metrics_snapshot.json',
    title: 'Observatory Metrics Snapshot',
    description: 'Pre-computed current summary metrics: active shutdowns, blocked site count, 30-day anomaly rate, BGP networks down, CF traffic level. Regenerated every 30 minutes.',
    format: 'JSON',
    size: '~1 KB',
    license: 'CC BY 4.0',
    url: '/data/metrics_snapshot.json',
    updatedAt: metricsUpdatedAt(),
  },
]

const formatColor: Record<string, string> = {
  JSON: 'var(--color-accent)',
  CSV:  'var(--color-warning)',
}
---

<Observatory
  title="Dataset Downloads — Myanmar Internet Observatory"
  seoTitle="Myanmar Internet Data Downloads | Internet in Myanmar"
  metaDescription="Download open datasets: BGP outages, OONI timeseries, verified shutdowns, and blocked sites for Myanmar. All data under CC BY 4.0."
  datasetName="Myanmar Internet Observatory — Research Datasets"
  datasetDescription="BGP outage events, OONI censorship timeseries, Access Now KeepItOn shutdown records, and blocked domain database for Myanmar. Open data under Creative Commons licences."
  pageUrl="https://www.internetinmyanmar.com/observatory/data/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="font-headline text-3xl md:text-4xl mb-4">Dataset Downloads</h1>
    <p class="opacity-70 mb-8 max-w-2xl">
      All datasets underlying the Internet in Myanmar Observatory are available for download and reuse under open licences.
      Updated continuously by automated agents running on our monitoring infrastructure.
    </p>

    <!-- Citation block -->
    <div class="border border-white/10 rounded-lg p-5 mb-10 bg-white/[0.02]">
      <div class="font-mono text-xs text-[color:var(--color-accent)] mb-2 tracking-widest uppercase">Citation</div>
      <p class="font-mono text-sm opacity-70">
        Internet in Myanmar Observatory, internetinmyanmar.com.
        OONI data: CC BY 4.0 · Cloudflare Radar: CC BY-NC 4.0 · Access Now STOP Dataset: CC BY 4.0.
      </p>
    </div>

    <!-- Dataset cards -->
    <div class="space-y-4">
      {datasets.map(ds => (
        <div class="border border-white/10 rounded-lg p-5 hover:border-white/20 transition-colors">
          <div class="flex items-start justify-between gap-4 mb-2">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs px-2 py-0.5 rounded border border-white/10" style={`color:${formatColor[ds.format] ?? '#fff'}`}>
                {ds.format}
              </span>
              <h2 class="font-headline text-lg">{ds.title}</h2>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
              <span class="font-mono text-xs opacity-40">{ds.size}</span>
              <a
                href={ds.url}
                download
                class="font-mono text-xs px-3 py-1.5 border border-[color:var(--color-accent)] text-[color:var(--color-accent)] rounded hover:bg-[color:var(--color-accent)] hover:text-[color:var(--color-bg-dark)] transition-colors"
              >
                ↓ Download
              </a>
            </div>
          </div>
          <p class="text-sm opacity-60 mb-2">{ds.description}</p>
          <div class="font-mono text-xs opacity-30">
            {ds.file} · {ds.license}
            {ds.updatedAt && <span> · updated {ds.updatedAt}</span>}
          </div>
        </div>
      ))}
    </div>

    <!-- Sources & provenance -->
    <div class="mt-12 border-t border-white/10 pt-8 text-sm opacity-60 space-y-2">
      <p>
        <strong class="opacity-80">OONI data</strong> is collected by volunteer researchers running
        <a href="https://ooni.org/install/" target="_blank" rel="noopener" class="underline hover:opacity-100">OONI Probe</a>
        inside Myanmar and published under CC BY 4.0. Monthly timeseries are aggregated from raw
        <code class="font-mono text-xs">web_connectivity</code> measurements via the OONI API.
      </p>
      <p>
        <strong class="opacity-80">Cloudflare Radar</strong> data is published under CC BY-NC 4.0 and
        retrieved via the <a href="https://radar.cloudflare.com" target="_blank" rel="noopener" class="underline hover:opacity-100">Radar API</a>.
        Not included in direct CSV downloads per licence terms; available via the Observatory charts.
      </p>
      <p>
        <strong class="opacity-80">BGP data</strong> is generated by the IIM BGP Observatory, active from April 2026.
        Our pipeline monitors 130+ Myanmar autonomous systems via 800+ global route collectors and classifies
        prefix withdrawal events. Methodology documented in the
        <a href="/observatory/bgp/" class="underline hover:opacity-100">BGP Network Status</a> page.
      </p>
      <p>
        <strong class="opacity-80">Shutdown events</strong> are sourced from the
        <a href="https://www.accessnow.org/keepiton/" target="_blank" rel="noopener" class="underline hover:opacity-100">Access Now STOP Dataset</a>
        (CC BY 4.0), cross-validated against OONI anomaly spikes and BGP withdrawal events.
      </p>
    </div>
  </div>
</Observatory>
