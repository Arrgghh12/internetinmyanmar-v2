---
import Base from '../../layouts/Base.astro'

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Anna',
  jobTitle: 'Editor-in-Chief',
  description: "Journalist specializing in Myanmar's media landscape, digital rights, and internet freedom.",
  url: 'https://www.internetinmyanmar.com/about/anna/',
  worksFor: {
    '@type': 'Organization',
    name: 'Internet in Myanmar',
    url: 'https://www.internetinmyanmar.com',
  },
  knowsAbout: ['Myanmar', 'internet censorship', 'digital rights', 'media freedom', 'Southeast Asia', 'internet shutdowns'],
  knowsLanguage: ['en', 'fr', 'es', 'it'],
}

// Obfuscated contact — assembled client-side to avoid harvesting
const emailUser = 'admin'
const emailDomain = 'internetinmyanmar.com'
---
<Base
  title="Anna — Editor-in-Chief"
  seoTitle="Anna | Internet in Myanmar"
  metaDescription="Anna is a journalist specializing in Myanmar's media landscape, digital rights, and internet freedom."
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <div class="max-w-3xl mx-auto px-4 py-16">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">Editorial</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-8">Anna</h1>

    <div class="flex flex-col md:flex-row gap-8 mb-10">
      <div class="md:w-48 flex-shrink-0">
        <div class="w-full aspect-square bg-white/5 border border-white/10 rounded-lg flex items-center justify-center text-white/20 font-mono text-sm">
          Photo
        </div>
      </div>
      <div class="space-y-4 opacity-85">
        <p class="text-lg">
          Anna is a journalist specializing in Myanmar's media landscape, digital rights, and internet freedom. She has closely followed the military junta's systematic censorship of online information since the 2021 coup.
        </p>
        <p>
          Her work appears at the intersection of investigative journalism and technical analysis — translating complex network measurement data into accessible, credible reporting for international audiences, press freedom organizations, and policymakers.
        </p>
        <p>
          Anna writes in English, French, Spanish, and Italian.
        </p>
        <p>
          <span class="text-[color:var(--color-accent)] font-mono text-sm">Contact: </span>
          <a
            id="contact-link"
            href="#"
            class="font-mono text-sm text-white/70 hover:text-white underline underline-offset-2 transition-colors"
            aria-label="Send email to the editorial team"
          >reveal email</a>
        </p>
      </div>
    </div>
  </div>

  <script define:vars={{ emailUser, emailDomain }}>
    const link = document.getElementById('contact-link')
    link.addEventListener('click', (e) => {
      e.preventDefault()
      const addr = emailUser + '@' + emailDomain
      link.href = 'mailto:' + addr
      link.textContent = addr
      link.onclick = null
    })
  </script>
</Base>
