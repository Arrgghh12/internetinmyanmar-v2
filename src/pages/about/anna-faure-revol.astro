---
import Base from '../../layouts/Base.astro'

---
<Base
  title="Anna Faure Revol — Editor-in-Chief"
  seoTitle="Anna Faure Revol | Internet in Myanmar"
  metaDescription="Anna Faure Revol is a journalist specializing in Myanmar's media landscape, digital rights, and internet freedom."
>
  <div class="max-w-3xl mx-auto px-4 py-16">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">Editorial</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-8">Anna</h1>

    <div class="flex flex-col md:flex-row gap-8 mb-10">
      <div class="md:w-48 flex-shrink-0">
        <div class="w-full aspect-square bg-white/5 border border-white/10 rounded-lg flex items-center justify-center text-white/20 font-mono text-sm">
          Photo
        </div>
      </div>
      <div class="space-y-4 opacity-85">
        <p class="text-lg">
          Anna is a journalist specializing in Myanmar's media landscape, digital rights, and internet freedom. She has closely followed the military junta's systematic censorship of online information since the 2021 coup.
        </p>
        <p>
          Her work appears at the intersection of investigative journalism and technical analysis — translating complex network measurement data into accessible, credible reporting for international audiences, press freedom organizations, and policymakers.
        </p>
        <p>
          Anna writes in English, French, Spanish, and Italian.
        </p>
        <div class="flex gap-4 pt-2">
          <a
            href="https://linkedin.com/in/anna-faure-revol"
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-sm text-[color:var(--color-accent)] hover:underline"
          >
            LinkedIn →
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>
