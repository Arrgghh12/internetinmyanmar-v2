---
import Base from '../../layouts/Base.astro'

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://www.internetinmyanmar.com/about/sacha-nakeo/#person',
  name: 'Sacha Nakeo',
  jobTitle: 'Editor-in-Chief',
  description: "Journalist covering Myanmar's digital rights, internet freedom, and media landscape. Her reporting is grounded in network measurement data provided by a dedicated technical team.",
  url: 'https://www.internetinmyanmar.com/about/sacha-nakeo/',
  worksFor: {
    '@type': 'NewsMediaOrganization',
    '@id': 'https://www.internetinmyanmar.com/#organization',
    name: 'Internet in Myanmar',
    url: 'https://www.internetinmyanmar.com',
  },
  image: 'https://media.internetinmyanmar.com/images/sacha-nakeo-editor-in-chief-internet-in-myanmar/sacha-nakeo-portrait-1.jpg',
  knowsAbout: ['Myanmar', 'internet censorship', 'digital rights', 'media freedom', 'Southeast Asia', 'internet shutdowns'],
  knowsLanguage: ['en', 'fr', 'es', 'it'],
  sameAs: [],
}

// Obfuscated contact — assembled client-side to avoid harvesting
const emailUser = 'admin'
const emailDomain = 'internetinmyanmar.com'
---
<Base
  title="Sacha Nakeo — Editor-in-Chief"
  seoTitle="Sacha Nakeo | Internet in Myanmar"
  metaDescription="Sacha Nakeo is a journalist covering Myanmar's digital rights, internet freedom, and media landscape, backed by independent technical data."
  ogImage="https://media.internetinmyanmar.com/images/sacha-nakeo-editor-in-chief-internet-in-myanmar/sacha-nakeo-portrait-1.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <div class="max-w-3xl mx-auto px-4 py-16">
    <div class="font-mono text-xs text-[color:var(--color-accent)] mb-3 uppercase tracking-widest">Editorial</div>
    <h1 class="font-headline text-3xl md:text-4xl mb-8">Sacha Nakeo</h1>

    <div class="flex flex-col md:flex-row gap-8 mb-10">
      <div class="md:w-48 flex-shrink-0">
        <img
          src="https://media.internetinmyanmar.com/images/sacha-nakeo-editor-in-chief-internet-in-myanmar/sacha-nakeo-portrait-1.jpg"
          alt="Sacha Nakeo, Editor-in-Chief of Internet in Myanmar"
          width="192"
          height="192"
          loading="eager"
          fetchpriority="high"
          class="w-full aspect-square object-cover rounded-lg"
        />
      </div>
      <div class="space-y-4 opacity-85">
        <p class="text-lg">
          Sacha Nakeo is a journalist specializing in Myanmar's media landscape, digital rights, and internet freedom. She has closely followed the military junta's systematic censorship of online information since the 2021 coup.
        </p>
        <p>
          Her reporting draws on a rigorous technical infrastructure — network measurement data from OONI and Cloudflare Radar, BGP routing surveillance, and independent dataset analysis — to produce credible, evidence-based journalism for international audiences, press freedom organizations, and policymakers.
        </p>
        <p>
          <span class="text-[color:var(--color-accent)] font-mono text-sm">Contact: </span>
          <a
            id="contact-link"
            href="#"
            class="font-mono text-sm text-white/70 hover:text-white underline underline-offset-2 transition-colors"
            aria-label="Send email to the editorial team"
          >reveal email</a>
        </p>
      </div>
    </div>
  </div>

  <script define:vars={{ emailUser, emailDomain }}>
    const link = document.getElementById('contact-link')
    link.addEventListener('click', (e) => {
      e.preventDefault()
      const addr = emailUser + '@' + emailDomain
      link.href = 'mailto:' + addr
      link.textContent = addr
      link.onclick = null
    })
  </script>
</Base>
