---
import Base from '../layouts/Base.astro'
import CfRadarBanner from '../components/CfRadarBanner.astro'
import NewsletterForm from '../components/NewsletterForm.astro'
import { getCollection } from 'astro:content'
import stats from '../content/observatory/stats.json'
import cfOutages from '../data/cf-radar-outages.json'

const allArticles = await getCollection('articles', ({ data }) =>
  !data.draft && !data.unlisted && data.lang === 'en'
)

// Featured analysis: Censorship or Policy, newest first
const featured = allArticles
  .filter(a => a.data.categories.includes('Censorship & Shutdowns') || a.data.categories.includes('Policy & Regulation'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 2)

// Digest — all entries sorted newest first
const allDigest = (await getCollection('digest', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())

const tickerItems  = allDigest.slice(0, 6)
const latestDigest = allDigest.slice(0, 6)

// Source stats
const sourceCounts: Record<string, number> = {}
for (const d of allDigest) {
  sourceCounts[d.data.source] = (sourceCounts[d.data.source] || 0) + 1
}
const topSources = Object.entries(sourceCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 9)

// Category snapshots
const shutdownItems    = allDigest.filter(d => d.data.category === 'Shutdown').slice(0, 3)
const censorshipItems  = allDigest.filter(d => d.data.category === 'Censorship').slice(0, 3)
const surveillanceItems = allDigest.filter(d => d.data.category === 'Surveillance').slice(0, 3)

const digestCategoryColor: Record<string, string> = {
  Shutdown:     'var(--color-danger)',
  Censorship:   'var(--color-danger)',
  Arrest:       'var(--color-warning)',
  Surveillance: 'var(--color-danger)',
  Data:         'var(--color-accent)',
  Policy:       'var(--color-warning)',
  Other:        'rgba(255,255,255,0.3)',
}

const articleCategoryColor: Record<string, string> = {
  'Censorship & Shutdowns':   'var(--color-danger)',
  'VPN & Security':           'var(--color-accent)',
  'ISP & Broadband':          'var(--color-accent)',
  'Mobile & Data Plans':      'var(--color-warning)',
  'Telecom & Infrastructure': 'var(--color-accent)',
  'Digital Services':         'var(--color-warning)',
  'Policy & Regulation':      'var(--color-warning)',
}

const tierLabel: Record<string, string> = { A: 'Tier A', B: 'Tier B', C: 'Tier C', D: 'Tier D' }
const tierColor: Record<string, string> = {
  A: 'var(--color-accent)',
  B: 'var(--color-warning)',
  C: 'rgba(255,255,255,0.4)',
  D: 'rgba(255,255,255,0.25)',
}
---
<Base
  title="Myanmar Internet Censorship Monitor"
  seoTitle="Myanmar Internet Censorship Monitor | Internet in Myanmar"
  metaDescription="Independent tracking of internet shutdowns, censorship, and connectivity in Myanmar. Real-time OONI data, analysis, and reports."
>

  <!-- Hero -->
  <section class="border-b border-white/10 py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="font-mono text-xs text-[color:var(--color-accent)] mb-4 tracking-widest uppercase">
        Independent Monitor · Since 2021
      </div>
      <h1 class="font-headline text-4xl md:text-6xl leading-tight mb-6">
        Monitoring Myanmar's<br/>Digital Crackdown
      </h1>
      <p class="text-lg md:text-xl opacity-70 max-w-2xl mb-8">
        Real-time tracking of internet shutdowns, website censorship, and
        telecom infrastructure in Myanmar — for journalists, researchers, and
        international organizations.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/observatory/" class="px-6 py-3 bg-[color:var(--color-accent)] text-[color:var(--color-bg-dark)] font-semibold rounded hover:opacity-90 transition-opacity">
          Observatory →
        </a>
        <a href="/censorship/" class="px-6 py-3 border border-white/20 rounded hover:border-white/50 transition-colors">
          Reports & Analysis
        </a>
      </div>
    </div>
  </section>

  <!-- Observatory stats strip -->
  <section class="border-b border-white/10 py-10 px-4 bg-white/2">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-2 mb-6 font-mono text-xs text-[color:var(--color-accent)]">
        <span class="inline-block w-2 h-2 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span>
        LIVE OBSERVATORY DATA
      </div>
      <a href="/observatory/shutdown-tracker/">
        <CfRadarBanner
          activeOutages={cfOutages.activeOutages}
          lastUpdated={cfOutages.lastUpdated}
        />
      </a>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/observatory/shutdown-tracker/" class="p-6 border border-[color:var(--color-danger)]/30 rounded bg-[color:var(--color-danger)]/5 hover:border-[color:var(--color-danger)]/60 transition-colors block">
          <div class="font-mono text-4xl font-bold text-[color:var(--color-danger)] mb-1">
            {stats.activeShutdowns}
          </div>
          <div class="text-sm opacity-70">Active regional shutdowns</div>
        </a>
        <a href="/observatory/shutdown-tracker/" class="p-6 border border-white/10 rounded hover:border-white/30 transition-colors block">
          <div class="font-mono text-4xl font-bold text-[color:var(--color-warning)] mb-1">
            {stats.blockedSites.toLocaleString()}
          </div>
          <div class="text-sm opacity-70">Sites blocked by OONI measurement</div>
        </a>
        <a href="/observatory/shutdown-tracker/" class="p-6 border border-white/10 rounded hover:border-white/30 transition-colors block">
          <div class="font-mono text-4xl font-bold text-[color:var(--color-accent)] mb-1">
            {stats.daysSinceLastMajorOutage}
          </div>
          <div class="text-sm opacity-70">Days since last major outage</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Digest ticker -->
  {tickerItems.length > 0 && (
    <section class="border-b border-white/10 py-3 overflow-hidden bg-white/[0.02]">
      <div id="ticker-track" style="display:flex;width:max-content;animation:ticker-scroll 50s linear infinite">
        {[...tickerItems, ...tickerItems].map((item) => (
          <a
            href={`/digest/${item.slug}/`}
            style="display:flex;align-items:center;gap:12px;padding:4px 24px;white-space:nowrap;border-right:1px solid rgba(255,255,255,0.08);text-decoration:none;opacity:0.85"
            onmouseenter="document.getElementById('ticker-track').style.animationPlayState='paused'"
            onmouseleave="document.getElementById('ticker-track').style.animationPlayState='running'"
          >
            <span
              class="font-mono text-[10px] tracking-widest uppercase px-2 py-0.5 rounded"
              style={`color: ${digestCategoryColor[item.data.category] ?? 'rgba(255,255,255,0.4)'}; border: 1px solid currentColor`}
            >
              {item.data.category}
            </span>
            <span class="text-xs opacity-50">{item.data.source}</span>
            <span class="text-sm opacity-80">{item.data.title}</span>
            <span class="text-xs opacity-30 ml-1">→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Latest from the Digest -->
  <section class="py-16 px-4 border-b border-white/10">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-2">
        <div>
          <div class="font-mono text-xs text-[color:var(--color-accent)] tracking-widest uppercase mb-1">Digest</div>
          <h2 class="font-headline text-2xl">Latest from our sources</h2>
        </div>
        <a href="/digest/" class="text-xs font-mono opacity-50 hover:opacity-100 transition-opacity">All {allDigest.length} entries →</a>
      </div>
      <p class="text-sm opacity-40 mb-8">Curated from {topSources.length}+ trusted sources on Myanmar's digital environment</p>

      {latestDigest.length > 0 ? (
        <div class="grid md:grid-cols-3 gap-4">
          {latestDigest.map((item) => (
            <a href={`/digest/${item.slug}/`} class="border border-white/10 rounded p-5 hover:border-white/30 transition-colors block group">
              <div class="flex items-center justify-between mb-3">
                <span
                  class="font-mono text-[10px] tracking-widest uppercase"
                  style={`color: ${digestCategoryColor[item.data.category] ?? 'rgba(255,255,255,0.4)'}`}
                >
                  {item.data.category}
                </span>
                <span
                  class="font-mono text-[10px] px-1.5 py-0.5 rounded"
                  style={`color: ${tierColor[item.data.sourceTier] ?? 'rgba(255,255,255,0.3)'}; border: 1px solid currentColor`}
                >
                  {tierLabel[item.data.sourceTier] ?? item.data.sourceTier}
                </span>
              </div>
              <h3 class="font-headline text-base leading-snug mb-3 group-hover:opacity-80 transition-opacity">
                {item.data.title}
              </h3>
              <div class="flex items-center justify-between text-xs opacity-40 font-mono mt-auto">
                <span>{item.data.source}</span>
                <span>{item.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="opacity-40 text-sm font-mono">No digest entries yet.</p>
      )}
    </div>
  </section>

  <!-- Source stats bar -->
  {topSources.length > 0 && (
    <section class="border-b border-white/10 py-6 px-4 bg-white/[0.015]">
      <div class="max-w-7xl mx-auto">
        <div class="font-mono text-[10px] text-[color:var(--color-accent)] tracking-widest uppercase mb-3">Coverage — tracked sources</div>
        <div class="flex flex-wrap gap-x-6 gap-y-2 items-baseline">
          {topSources.map(([source, count], i) => (
            <span class="flex items-baseline gap-2">
              <span class="text-sm opacity-70">{source}</span>
              <span class="font-mono text-xs font-bold text-[color:var(--color-accent)]">{count}</span>
              {i < topSources.length - 1 && <span class="opacity-20 hidden md:inline">·</span>}
            </span>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Category digest snapshot -->
  <section class="py-16 px-4 border-b border-white/10">
    <div class="max-w-7xl mx-auto">
      <div class="font-mono text-xs text-[color:var(--color-accent)] tracking-widest uppercase mb-2">By topic</div>
      <h2 class="font-headline text-2xl mb-8">Tracking key threats</h2>
      <div class="grid md:grid-cols-3 gap-8">

        <!-- Shutdowns -->
        <div>
          <div class="flex items-center gap-2 mb-4 pb-3 border-b border-[color:var(--color-danger)]/30">
            <span class="w-2 h-2 rounded-full bg-[color:var(--color-danger)]"></span>
            <span class="font-mono text-xs text-[color:var(--color-danger)] tracking-widest uppercase">Shutdowns</span>
          </div>
          <div class="space-y-4">
            {shutdownItems.map(item => (
              <a href={`/digest/${item.slug}/`} class="block group">
                <div class="text-sm leading-snug mb-1 group-hover:opacity-70 transition-opacity">{item.data.title}</div>
                <div class="font-mono text-[10px] opacity-35">{item.data.source} · {item.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
              </a>
            ))}
            {shutdownItems.length === 0 && <p class="text-xs opacity-30 font-mono">No entries yet</p>}
          </div>
        </div>

        <!-- Censorship -->
        <div>
          <div class="flex items-center gap-2 mb-4 pb-3 border-b border-[color:var(--color-danger)]/30">
            <span class="w-2 h-2 rounded-full bg-[color:var(--color-danger)]"></span>
            <span class="font-mono text-xs text-[color:var(--color-danger)] tracking-widest uppercase">Censorship</span>
          </div>
          <div class="space-y-4">
            {censorshipItems.map(item => (
              <a href={`/digest/${item.slug}/`} class="block group">
                <div class="text-sm leading-snug mb-1 group-hover:opacity-70 transition-opacity">{item.data.title}</div>
                <div class="font-mono text-[10px] opacity-35">{item.data.source} · {item.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
              </a>
            ))}
            {censorshipItems.length === 0 && <p class="text-xs opacity-30 font-mono">No entries yet</p>}
          </div>
        </div>

        <!-- Surveillance -->
        <div>
          <div class="flex items-center gap-2 mb-4 pb-3 border-b border-[color:var(--color-danger)]/30">
            <span class="w-2 h-2 rounded-full bg-[color:var(--color-danger)]"></span>
            <span class="font-mono text-xs text-[color:var(--color-danger)] tracking-widest uppercase">Surveillance</span>
          </div>
          <div class="space-y-4">
            {surveillanceItems.map(item => (
              <a href={`/digest/${item.slug}/`} class="block group">
                <div class="text-sm leading-snug mb-1 group-hover:opacity-70 transition-opacity">{item.data.title}</div>
                <div class="font-mono text-[10px] opacity-35">{item.data.source} · {item.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
              </a>
            ))}
            {surveillanceItems.length === 0 && <p class="text-xs opacity-30 font-mono">No entries yet</p>}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- In-depth analysis -->
  <section class="py-16 px-4 border-b border-white/10">
    <div class="max-w-7xl mx-auto">
      <div class="font-mono text-xs text-[color:var(--color-accent)] tracking-widest uppercase mb-2">Analysis</div>
      <h2 class="font-headline text-2xl mb-8">In-Depth Analysis</h2>
      {featured.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-6">
          {featured.map((article) => (
            <a href={`/articles/${article.slug}/`} class="border border-white/10 rounded p-6 hover:border-white/30 transition-colors block">
              <div class="font-mono text-xs mb-3" style={`color: ${articleCategoryColor[article.data.categories[0]] ?? 'var(--color-accent)'}`}>
                {article.data.categories[0]}
              </div>
              <h3 class="font-headline text-xl mb-3 leading-snug">{article.data.title}</h3>
              <p class="text-sm opacity-60 mb-4 line-clamp-3">{article.data.excerpt}</p>
              <div class="text-xs opacity-40 font-mono">
                {article.data.author.split(' ')[0]} · {article.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="opacity-40 text-sm font-mono">Analysis articles coming soon.</p>
      )}
    </div>
  </section>

  <!-- Observatory intro -->
  <section class="py-20 px-4 border-b border-white/10">
    <div class="max-w-7xl mx-auto">

      <div class="max-w-3xl mb-14">
        <div class="font-mono text-xs text-[color:var(--color-accent)] tracking-widest uppercase mb-3">The Observatory</div>
        <h2 class="font-headline text-3xl mb-5">Independent measurement infrastructure for Myanmar's digital environment</h2>
        <p class="opacity-70 leading-relaxed">
          Since the February 2021 military coup, <em>Internet in Myanmar</em> has operated as an
          independent technical monitor tracking internet shutdowns, censorship events, and network
          infrastructure changes in real time. Our measurement infrastructure combines four
          independent data streams — updated continuously since the coup's first day — to produce the
          most complete public picture of internet freedom in Myanmar available outside government
          sources. The data is used by journalists, human rights researchers, legal advocates, and
          international organizations documenting digital repression.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px bg-white/10 rounded-lg overflow-hidden">

        <!-- Pillar 1: OONI -->
        <div class="bg-[color:var(--color-bg-dark)] p-7">
          <div class="font-mono text-xs text-[color:var(--color-warning)] tracking-widest uppercase mb-3">Application layer</div>
          <h3 class="font-headline text-lg mb-3">OONI Censorship Detection</h3>
          <p class="text-sm opacity-65 leading-relaxed mb-4">
            We analyse OONI Web Connectivity measurements from probes inside Myanmar to detect
            URL-level censorship, DNS tampering, TCP/IP resets, and HTTP interference across all
            major ISPs. Five years of continuous data document which sites are blocked, on which
            networks, and when. The weekly anomaly breakdown chart shows the composition of each
            measurement period — ok, failure, anomaly, confirmed blocking — revealing whether
            elevated rates reflect new targeted blocks or broader network degradation.
          </p>
          <div class="space-y-1.5">
            <a href="/observatory/blocked-sites/" class="flex items-center gap-2 text-sm text-[color:var(--color-warning)] hover:opacity-80 transition-opacity">
              <span>→</span><span>Blocked Sites Monitor</span>
            </a>
            <a href="/observatory/shutdown-tracker/" class="flex items-center gap-2 text-sm opacity-45 hover:opacity-80 transition-opacity">
              <span>→</span><span>Shutdown Tracker</span>
            </a>
          </div>
        </div>

        <!-- Pillar 2: CF Radar -->
        <div class="bg-[color:var(--color-bg-dark)] p-7 border-l border-white/10">
          <div class="font-mono text-xs text-[color:var(--color-accent)] tracking-widest uppercase mb-3">Traffic layer</div>
          <h3 class="font-headline text-lg mb-3">Cloudflare Radar Traffic</h3>
          <p class="text-sm opacity-65 leading-relaxed mb-4">
            We overlay Cloudflare Radar Myanmar traffic volume against OONI anomaly rates to
            distinguish targeted content blocking from wholesale blackouts. An anomaly spike
            paired with a traffic drop is the strongest available technical signal of a deliberate
            population-level shutdown — the pattern seen during nightly curfews, Rakhine and Shan
            offensive blackouts, and the February 2021 coup. The 30-day Live Signal chart on the
            Observatory dashboard gives the fastest read on today's connectivity.
          </p>
          <div class="space-y-1.5">
            <a href="/observatory/shutdown-tracker/" class="flex items-center gap-2 text-sm text-[color:var(--color-accent)] hover:opacity-80 transition-opacity">
              <span>→</span><span>Shutdown Tracker + Chart</span>
            </a>
            <a href="/observatory/" class="flex items-center gap-2 text-sm opacity-45 hover:opacity-80 transition-opacity">
              <span>→</span><span>Observatory Dashboard</span>
            </a>
          </div>
        </div>

        <!-- Pillar 3: Access Now -->
        <div class="bg-[color:var(--color-bg-dark)] p-7 border-l border-white/10">
          <div class="font-mono text-xs text-[color:var(--color-danger)] tracking-widest uppercase mb-3">Verified shutdowns</div>
          <h3 class="font-headline text-lg mb-3">Access Now STOP Dataset</h3>
          <p class="text-sm opacity-65 leading-relaxed mb-4">
            We integrate Access Now's global human-verified shutdown registry, filtered to Myanmar
            and updated weekly. Each record is confirmed by researchers through direct community
            contact, cross-referenced with technical measurements. Events are overlaid on the
            shutdown tracker chart as coloured bands by type — full network, mobile, platform,
            throttle — and plotted on a regional map with a timeline scrubber to trace which
            administrative regions were simultaneously affected at any given month since 2021.
          </p>
          <div class="space-y-1.5">
            <a href="/observatory/shutdown-tracker/" class="flex items-center gap-2 text-sm text-[color:var(--color-danger)] hover:opacity-80 transition-opacity">
              <span>→</span><span>Verified Shutdown Map</span>
            </a>
          </div>
        </div>

        <!-- Pillar 4: BGP -->
        <div class="bg-[color:var(--color-bg-dark)] p-7 border-l border-white/10">
          <div class="font-mono text-xs opacity-50 tracking-widest uppercase mb-3">Routing layer</div>
          <h3 class="font-headline text-lg mb-3">BGP Routing Surveillance</h3>
          <p class="text-sm opacity-65 leading-relaxed mb-4">
            We monitor BGP routing activity across all Myanmar autonomous systems every five minutes,
            detecting network outages 2–15 minutes before any public alert. BGP prefix withdrawals
            are the fastest available evidence of a deliberate shutdown order. Our monitor covers
            mobile operators, ISPs, international gateways, and internet exchange points.
            Historical outage records are downloadable in JSON for independent research.
          </p>
          <div class="space-y-1.5">
            <a href="/observatory/bgp/" class="flex items-center gap-2 text-sm opacity-45 hover:opacity-80 transition-opacity">
              <span>→</span><span>BGP Network Status</span>
            </a>
          </div>
        </div>

      </div>

      <div class="mt-8 text-xs font-mono opacity-30">
        Data sources: <a href="https://explorer.ooni.org/country/MM" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 underline">OONI Explorer</a> ·
        <a href="https://radar.cloudflare.com" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 underline">Cloudflare Radar</a> ·
        <a href="https://www.accessnow.org/keepiton/" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 underline">Access Now STOP Dataset</a> ·
        <a href="https://stat.ripe.net" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 underline">RIPEstat (RIPE NCC)</a> ·
        <a href="https://ioda.inetintel.cc.gatech.edu" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 underline">IODA (Georgia Tech)</a> ·
        <a href="https://github.com/citizenlab/test-lists" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 underline">Citizen Lab Test Lists</a>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 text-center border-b border-white/10">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-headline text-3xl mb-4">Track Myanmar's internet in real time</h2>
      <p class="opacity-60 mb-8">
        Our Observatory pulls OONI measurement data twice daily. See what's blocked, when shutdowns start, and which networks are affected.
      </p>
      <a href="/observatory/" class="px-8 py-4 border border-[color:var(--color-accent)] text-[color:var(--color-accent)] rounded hover:bg-[color:var(--color-accent)] hover:text-[color:var(--color-bg-dark)] transition-colors font-semibold">
        Open the Observatory
      </a>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-16 px-4">
    <div class="max-w-xl mx-auto">
      <NewsletterForm />
    </div>
  </section>

</Base>

<style is:global>
  @keyframes ticker-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
