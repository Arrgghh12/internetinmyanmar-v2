---
import { getCollection } from 'astro:content'
import Article from '../../layouts/Article.astro'

export const prerender = true

export async function getStaticPaths() {
  const articles = await getCollection('articles', (a) => !a.data.draft && !a.data.archived)
  return articles.map((a) => ({ params: { slug: a.id.replace(/\.mdx$/, '') }, props: { article: a } }))
}

const { slug } = Astro.params
const { article } = Astro.props

const { Content } = await article.render()
const d = article.data
---
<Article
  title={d.title}
  seoTitle={d.seoTitle}
  metaDescription={d.metaDescription}
  slug={slug!}
  categories={d.categories}
  author={d.author}
  publishedAt={d.publishedAt}
  updatedAt={d.updatedAt}
  featuredImage={d.featuredImage}
  featuredImageAlt={d.featuredImageAlt}
  featuredImageCredit={d.featuredImageCredit}
  featuredImageCreditUrl={d.featuredImageCreditUrl}
  excerpt={d.excerpt}
  readingTime={d.readingTime}
  sources={d.sources}
  originalUrl={d.originalUrl}
  lang={d.lang}
>
  <Content />
</Article>
