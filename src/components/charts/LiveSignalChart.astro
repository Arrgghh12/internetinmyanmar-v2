---
import ooniDaily from '../../data/ooni-history-daily.json'
import cfTraffic from '../../data/cf-traffic.json'

// Build CF daily lookup by date string (YYYY-MM-DD)
const cfDailyMap: Record<string, number> = Object.fromEntries(
  (cfTraffic.daily || []).map((d: { timestamp: string; cf_traffic: number }) => [
    d.timestamp.slice(0, 10),
    d.cf_traffic,
  ])
)

// Last 30 days of OONI daily, enriched with CF daily value
const days = ooniDaily.slice(-30).map(d => ({
  date:      d.period,
  ooniRate:  d.anomaly_rate,
  cfTraffic: cfDailyMap[d.period] ?? null,
  total:     d.measurement_count,
  confirmed: d.confirmed_count,
  anomaly:   d.anomaly_count,
}))

const lastUpdated = days[days.length - 1]?.date ?? ''
---

<div class="mb-10">
  <div class="mb-2">
    <div class="font-headline text-base">Current Conditions — 30-Day Signal</div>
    <p class="text-xs font-mono opacity-40 mt-0.5">
      Bars = OONI anomaly rate · Teal line = Cloudflare Radar traffic index · updated daily
    </p>
  </div>

  <div class="border border-white/10 rounded-lg p-4 bg-[#0A1628]">
    <canvas
      id="live-signal-chart"
      role="img"
      aria-label="Dual-axis chart showing daily OONI anomaly rate as bars and Cloudflare Radar traffic as a teal line over the past 30 days"
      style="width:100%;height:200px"
    ></canvas>
  </div>

  <!-- HTML legend -->
  <div class="flex flex-wrap gap-x-5 gap-y-1 mt-2">
    <div class="flex items-center gap-1.5">
      <span class="inline-block w-3 h-3 rounded-sm flex-shrink-0" style="background:#F59E0B"></span>
      <span class="text-xs font-mono opacity-50">OONI anomaly rate</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="inline-block w-3 h-0.5 flex-shrink-0" style="background:#00D4C8"></span>
      <span class="text-xs font-mono opacity-50">Cloudflare Radar traffic (% of peak)</span>
    </div>
  </div>

  <div class="flex justify-between items-center mt-2 flex-wrap gap-2">
    <p class="text-xs font-mono opacity-30">
      OONI CC BY 4.0 · CF Radar CC BY-NC 4.0 · updated {lastUpdated}
    </p>
    <div class="flex items-center gap-2">
      <button id="live-signal-chart-png-btn" class="text-xs font-mono opacity-40 hover:opacity-70 transition-opacity border border-white/10 px-2 py-0.5 rounded cursor-pointer bg-transparent">↓ PNG</button>
      <button id="live-signal-chart-svg-btn" class="text-xs font-mono opacity-40 hover:opacity-70 transition-opacity border border-white/10 px-2 py-0.5 rounded cursor-pointer bg-transparent">↓ SVG</button>
      <a href="/data/ooni_timeseries.csv" download class="text-xs font-mono opacity-40 hover:opacity-70 transition-opacity border border-white/10 px-2 py-0.5 rounded">↓ CSV</a>
      <button id="live-signal-chart-embed-btn" class="text-xs font-mono opacity-40 hover:opacity-70 transition-opacity border border-white/10 px-2 py-0.5 rounded cursor-pointer bg-transparent">&lt;/&gt; Embed</button>
    </div>
  </div>

  <!-- Data table fallback -->
  <details class="mt-3">
    <summary class="text-xs font-mono opacity-30 cursor-pointer hover:opacity-60 select-none">Show data table</summary>
    <div class="mt-2 overflow-x-auto">
      <table class="w-full text-xs font-mono border-collapse">
        <thead>
          <tr class="border-b border-white/10">
            <th class="text-left py-1 pr-4 opacity-50">Date</th>
            <th class="text-right py-1 pr-4 opacity-50">Anomaly rate</th>
            <th class="text-right py-1 pr-4 opacity-50">CF traffic</th>
            <th class="text-right py-1 opacity-50">Measurements</th>
          </tr>
        </thead>
        <tbody>
          {days.map(d => (
            <tr class="border-b border-white/5">
              <td class="py-1 pr-4 opacity-70">{d.date}</td>
              <td class="py-1 pr-4 text-right" style={`color:${d.ooniRate > 20 ? '#EF4444' : d.ooniRate > 10 ? '#F59E0B' : '#22c55e'}`}>
                {d.ooniRate}%
              </td>
              <td class="py-1 pr-4 text-right" style="color:#00D4C8">{d.cfTraffic != null ? `${d.cfTraffic}%` : '—'}</td>
              <td class="py-1 text-right opacity-50">{d.total.toLocaleString()}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </details>
</div>

<script define:vars={{ days }}>
  (function () {
    const canvas = document.getElementById('live-signal-chart')
    if (!canvas) return

    function initChart() {
      const ctx = canvas.getContext('2d')
      if (!ctx) return

      const labels   = days.map(d => d.date)
      const ooniRates = days.map(d => d.ooniRate)
      const cfValues  = days.map(d => d.cfTraffic)

      const barColors = ooniRates.map(r =>
        r > 20 ? 'rgba(239,68,68,0.8)'
        : r > 10 ? 'rgba(245,158,11,0.8)'
        : 'rgba(34,197,94,0.7)'
      )

      canvas._chart = new window.Chart(ctx, {
        data: {
          labels,
          datasets: [
            {
              type: 'bar',
              label: 'OONI anomaly rate',
              data: ooniRates,
              backgroundColor: barColors,
              borderRadius: 2,
              yAxisID: 'yOoni',
            },
            {
              type: 'line',
              label: 'CF Radar traffic',
              data: cfValues,
              borderColor: '#00D4C8',
              backgroundColor: 'transparent',
              borderWidth: 1.5,
              pointRadius: 0,
              spanGaps: true,
              tension: 0.3,
              yAxisID: 'yCf',
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#0f1f3a',
              titleColor: '#94a3b8',
              bodyColor: '#e2e8f0',
              callbacks: {
                label: c => c.dataset.label === 'OONI anomaly rate'
                  ? ` OONI anomaly: ${c.parsed.y}%`
                  : ` CF traffic: ${c.parsed.y ?? '—'}% of peak`,
              },
            },
          },
          scales: {
            x: {
              ticks: { color: '#64748b', font: { size: 8 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 10 },
              grid: { color: 'rgba(255,255,255,0.04)' },
            },
            yOoni: {
              position: 'left',
              beginAtZero: true,
              max: 40,
              ticks: { color: '#64748b', font: { size: 9 }, callback: v => `${v}%` },
              grid: { color: 'rgba(255,255,255,0.04)' },
              title: { display: true, text: 'Anomaly %', color: '#64748b', font: { size: 9 } },
            },
            yCf: {
              position: 'right',
              beginAtZero: true,
              max: 100,
              ticks: { color: '#00D4C8', font: { size: 9 }, callback: v => `${v}%` },
              grid: { display: false },
              title: { display: true, text: 'CF Traffic %', color: '#00D4C8', font: { size: 9 } },
            },
          },
        },
      })
      const _png = document.getElementById('live-signal-chart-png-btn')
      if (_png) _png.addEventListener('click', () => {
        const a = document.createElement('a')
        a.href = canvas._chart.toBase64Image('image/png', 1)
        a.download = 'myanmar-internet-30day.png'
        a.click()
      })
      const _svg = document.getElementById('live-signal-chart-svg-btn')
      if (_svg) _svg.addEventListener('click', () => {
        const dataUrl = canvas._chart.toBase64Image('image/png', 1)
        const w = canvas.width, h = canvas.height
        const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}"><image href="${dataUrl}" width="${w}" height="${h}"/></svg>`
        const blob = new Blob([svg], { type: 'image/svg+xml' })
        const url = URL.createObjectURL(blob)
        const a = document.createElement('a'); a.href = url; a.download = 'myanmar-internet-30day.svg'; a.click()
        URL.revokeObjectURL(url)
      })
      const _emb = document.getElementById('live-signal-chart-embed-btn')
      if (_emb) _emb.addEventListener('click', () => {
        navigator.clipboard.writeText('<CensorshipChart type="live-signal" />')
          .then(() => { _emb.textContent = '✓ Copied'; setTimeout(() => { _emb.textContent = '</> Embed' }, 2000) })
          .catch(() => {})
      })
    }

    if (window.Chart) {
      initChart()
    } else {
      const s = document.createElement('script')
      s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js'
      s.onload = initChart
      document.head.appendChild(s)
    }
  })()
</script>
