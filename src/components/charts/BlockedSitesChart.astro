---
import blockedSites from '../../data/blocked-sites.json'

const CATEGORY_COLORS: Record<string, string> = {
  'Social Media':       'rgba(245,158,11,0.85)',
  'News & Media':       'rgba(239,68,68,0.85)',
  'Civil Society':      'rgba(139,92,246,0.8)',
  'VPN & Circumvention':'rgba(0,212,200,0.75)',
}

// Top 12 sites by anomaly rate, descending
const top12 = [...blockedSites.sites]
  .sort((a, b) => b.rate - a.rate)
  .slice(0, 12)
---

<div class="mb-8 not-prose">
  <div class="mb-2">
    <div class="font-headline text-base">Myanmar's Censorship Infrastructure, Pre-Election</div>
    <p class="text-xs font-mono opacity-40 mt-0.5">OONI anomaly rate by domain · Jan 2024 – Apr 2026 · top 12 most-blocked sites</p>
  </div>
  <div class="border border-white/10 rounded-lg p-4 bg-[#0A1628]">
    <canvas id="blocked-sites-chart" style="width:100%;height:320px"></canvas>
  </div>

  <!-- HTML legend -->
  <div class="flex flex-wrap gap-x-5 gap-y-1 mt-2">
    {Object.entries(CATEGORY_COLORS).map(([cat, color]) => (
      <div class="flex items-center gap-1.5">
        <span class="inline-block w-3 h-3 rounded-sm flex-shrink-0" style={`background:${color}`}></span>
        <span class="text-xs font-mono opacity-50">{cat}</span>
      </div>
    ))}
  </div>
  <p class="text-xs font-mono opacity-30 mt-1">
    OONI Web Connectivity · anomaly = blocked or unreachable from within Myanmar ·
    <a href="https://ooni.org" target="_blank" rel="noopener" class="underline hover:opacity-60">CC BY 4.0</a>
  </p>
</div>

<script define:vars={{ sites: top12, categoryColors: CATEGORY_COLORS }}>
  (function () {
    const canvas = document.getElementById('blocked-sites-chart')
    if (!canvas) return

    function initChart() {
      const ctx = canvas.getContext('2d')
      if (!ctx) return

      const labels = sites.map(s => s.domain)
      const data   = sites.map(s => s.rate)
      const colors = sites.map(s => categoryColors[s.category] || 'rgba(100,116,139,0.7)')

      new window.Chart(ctx, {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Anomaly Rate (%)',
            data,
            backgroundColor: colors,
            borderRadius: 3,
          }],
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#0f1f3a',
              titleColor: '#94a3b8',
              bodyColor: '#e2e8f0',
              callbacks: {
                label: c => ` ${c.parsed.x}% of measurements anomalous`,
                afterLabel: c => ` Category: ${sites[c.dataIndex].category}`,
              },
            },
          },
          scales: {
            x: {
              beginAtZero: true,
              max: 100,
              ticks: { color: '#64748b', font: { size: 9 }, callback: v => `${v}%` },
              grid:  { color: 'rgba(255,255,255,0.04)' },
              title: { display: true, text: 'OONI Anomaly Rate (%)', color: '#64748b', font: { size: 9 } },
            },
            y: {
              ticks: { color: '#94a3b8', font: { size: 10, family: 'monospace' } },
              grid:  { color: 'rgba(255,255,255,0.04)' },
            },
          },
        },
      })
    }

    if (window.Chart) {
      initChart()
    } else {
      const s = document.createElement('script')
      s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js'
      s.onload = initChart
      document.head.appendChild(s)
    }
  })()
</script>
