---
import Base from './Base.astro'
import SchemaOrg from '../components/SchemaOrg.astro'

interface Props {
  title: string
  seoTitle: string
  metaDescription: string
  slug: string          // passed from [slug].astro params (filename-based)
  categories: string[]
  author: string
  publishedAt: Date
  updatedAt?: Date
  featuredImage?: string
  featuredImageAlt?: string
  featuredImageCredit?: string
  featuredImageCreditUrl?: string
  excerpt: string
  readingTime?: number
  lang?: string
  sources?: string[]
  originalUrl?: string
  faq?: { q: string; a: string }[]
  noindex?: boolean
}

const {
  title,
  seoTitle,
  metaDescription,
  slug,
  categories,
  author,
  publishedAt,
  updatedAt,
  featuredImage,
  featuredImageAlt,
  featuredImageCredit,
  featuredImageCreditUrl,
  excerpt,
  readingTime,
  lang = 'en',
  sources = [],
  originalUrl,
  faq,
  noindex = false,
} = Astro.props

const canonicalUrl = new URL(`/articles/${slug}/`, Astro.site).href
const isStale = (Date.now() - publishedAt.valueOf()) > 1000 * 60 * 60 * 24 * 548 // 18 months

const categoryHref: Record<string, string> = {
  'Censorship & Shutdowns':   '/censorship/',
  'VPN & Security':           '/security/',
  'ISP & Broadband':          '/broadband/',
  'Mobile & Data Plans':      '/mobile/',
  'Telecom & Infrastructure': '/infrastructure/',
  'Digital Services':         '/digital-services/',
  'Policy & Regulation':      '/policy/',
}
const primaryCategory = categories[0]
---
<Base
  {title}
  {seoTitle}
  {metaDescription}
  {canonicalUrl}
  ogImage={featuredImage}
  ogType="article"
  {lang}
  {noindex}
>
  <SchemaOrg
    type="article"
    headline={title}
    datePublished={publishedAt.toISOString()}
    dateModified={updatedAt?.toISOString()}
    authorName={author}
    image={featuredImage}
    url={canonicalUrl}
    description={excerpt}
    articleSection={primaryCategory}
    slot="head"
  />
  {faq && faq.length > 0 && (
    <script type="application/ld+json" slot="head" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    })} />
  )}
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.internetinmyanmar.com/' },
      { '@type': 'ListItem', position: 2, name: primaryCategory, item: `https://www.internetinmyanmar.com${categoryHref[primaryCategory] ?? '/'}` },
      { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
    ],
  })} />

  <article class="max-w-3xl mx-auto px-4 py-12" data-pagefind-body lang={lang}>

    <!-- Breadcrumb -->
    <nav class="text-xs opacity-50 mb-6 font-mono">
      <a href="/" class="hover:opacity-100">Home</a>
      <span class="mx-2">›</span>
      <a href={categoryHref[primaryCategory] ?? '/'} class="hover:opacity-100">{primaryCategory}</a>
    </nav>

    <!-- Stale notice -->
    {isStale && (
      <div class="mb-6 px-4 py-3 rounded border border-[color:var(--color-warning)] text-[color:var(--color-warning)] text-sm">
        ⚠️ First published in {publishedAt.getFullYear()}. Some figures may be outdated.
      </div>
    )}

    <!-- Featured image -->
    {featuredImage && (
      <figure class="mb-8">
        <img
          src={featuredImage}
          alt={featuredImageAlt ?? ''}
          width="1200"
          height="675"
          class="w-full rounded aspect-video object-cover"
          loading="eager"
          fetchpriority="high"
        />
        {featuredImageCredit && (
          <figcaption class="text-xs opacity-40 mt-1.5 font-mono">
            Source: <a href={featuredImageCreditUrl ?? featuredImageCredit} target="_blank" rel="noopener noreferrer" class="underline hover:opacity-70">{featuredImageCredit}</a>
          </figcaption>
        )}
      </figure>
    )}

    <!-- H1 -->
    <h1 class="font-headline text-3xl md:text-4xl leading-tight mb-4">{title}</h1>

    <!-- Byline -->
    <div class="flex items-center gap-3 text-sm opacity-60 mb-10 pb-6 border-b border-white/10">
      <span>By <strong class="opacity-100">{author}</strong></span>
      <span>·</span>
      <time datetime={publishedAt.toISOString()}>
        {publishedAt.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {readingTime && (
        <>
          <span>·</span>
          <span>{readingTime} min read</span>
        </>
      )}
    </div>

    <!-- Article body -->
    <div class="prose prose-invert max-w-none
      prose-headings:font-headline
      prose-a:text-[color:var(--color-accent)]
      prose-code:font-mono">
      <slot />
    </div>

    <!-- Sources -->
    {sources.length > 0 && (
      <div class="mt-12 pt-6 border-t border-white/10">
        <h2 class="font-headline text-lg mb-3">Sources</h2>
        <ul class="space-y-1 text-sm">
          {sources.map((src) => (
            <li>
              <a href={src} class="text-[color:var(--color-accent)] hover:underline break-all" target="_blank" rel="noopener noreferrer">
                {src}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Author bio -->
    <div class="mt-10 pt-6 border-t border-white/10 flex gap-4 items-start">
      <div class="shrink-0 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-lg font-headline">
        SN
      </div>
      <div>
        <div class="font-semibold mb-1">
          <a href="/about/sacha-nakeo/" class="hover:text-[color:var(--color-accent)]">Sacha Nakeo</a>
        </div>
        <p class="text-sm opacity-70">
          Sacha Nakeo is a journalist specializing in Myanmar's media landscape, digital rights, and internet freedom.
          She has closely followed the military junta's systematic censorship of online information since the 2021 coup.
        </p>
      </div>
    </div>

  </article>
</Base>
