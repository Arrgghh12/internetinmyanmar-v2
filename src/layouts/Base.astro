---
import { SEO } from 'astro-seo'
import SchemaOrg from '../components/SchemaOrg.astro'
import '../styles/global.css'

interface Props {
  title: string
  seoTitle: string
  metaDescription: string
  canonicalUrl?: string
  ogImage?: string
  ogType?: string
  lang?: string
  noindex?: boolean
}

const {
  title,
  seoTitle,
  metaDescription,
  canonicalUrl = Astro.url.pathname.endsWith('/')
    ? Astro.url.href
    : Astro.url.href.replace(Astro.url.pathname, Astro.url.pathname + '/'),
  ogImage = '/og-default.png',
  ogType = 'website',
  lang = 'en',
  noindex = false,
} = Astro.props

// Build language switcher URLs from the current pathname
const currentPath = Astro.url.pathname
const LOCALES = ['en', 'fr', 'es', 'it'] as const
const LOCALE_LABELS: Record<string, string> = { en: 'EN', fr: 'FR', es: 'ES', it: 'IT' }

function getLocalePath(targetLang: string): string {
  // Strip current locale prefix if present (/fr/..., /es/..., /it/..., /my/...)
  const prefixedLocales = ['fr', 'es', 'it', 'my']
  let pathWithoutLocale = currentPath
  for (const loc of prefixedLocales) {
    if (currentPath === `/${loc}` || currentPath.startsWith(`/${loc}/`)) {
      pathWithoutLocale = currentPath.slice(loc.length + 1) || '/'
      break
    }
  }
  if (!pathWithoutLocale.startsWith('/')) pathWithoutLocale = '/' + pathWithoutLocale
  return targetLang === 'en' ? pathWithoutLocale : `/${targetLang}${pathWithoutLocale}`
}

const nav = [
  { label: 'Censorship', href: '/censorship/' },
  {
    label: 'Connectivity',
    children: [
      { label: 'ISP & Broadband',          href: '/broadband/' },
      { label: 'Mobile & Data Plans',      href: '/mobile/' },
      { label: 'Telecom & Infrastructure', href: '/infrastructure/' },
    ],
  },
  {
    label: 'Guides',
    children: [
      { label: 'VPN & Security',  href: '/security/' },
      { label: 'Digital Services', href: '/digital-services/' },
    ],
  },
  { label: 'Policy', href: '/policy/' },
  {
    label: 'Observatory',
    children: [
      { label: 'BGP Network Status',    href: '/observatory/bgp/' },
      { label: 'Blocked Sites Monitor', href: '/observatory/blocked-sites/' },
      { label: 'Shutdown Tracker',      href: '/observatory/shutdown-tracker/' },
    ],
  },
  { label: 'Digest', href: '/digest/' },
  { label: 'About', href: '/about/mission/' },
]
---
<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Internet in Myanmar" href="/rss.xml" />
    <link rel="preload" as="font" type="font/woff2" href="https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Inter — non-blocking load -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;510;590;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;510;590;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;510;590;700&display=swap" /></noscript>
    <!-- Myanmar fonts — only on lang=my pages -->
    {lang === 'my' && (
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Padauk:wght@400;700&family=Noto+Sans+Myanmar:wght@400;500;700&display=swap" />
    )}
    <!-- hreflang -->
    {LOCALES.map((loc) => (
      <link rel="alternate" hreflang={loc} href={new URL(getLocalePath(loc), Astro.site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(getLocalePath('en'), Astro.site).href} />
    <SEO
      title={seoTitle}
      description={metaDescription}
      canonical={canonicalUrl}
      noindex={noindex}
      nofollow={noindex}
      openGraph={{
        basic: {
          title: seoTitle,
          type: ogType,
          image: new URL(ogImage, Astro.site).href,
          url: canonicalUrl,
        },
        optional: {
          description: metaDescription,
          siteName: 'Internet in Myanmar',
          locale: lang,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: seoTitle,
        description: metaDescription,
        image: new URL(ogImage, Astro.site).href,
      }}
    />
    <SchemaOrg type="organization" />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">

    <!-- Utility bar -->
    <div class="border-b border-white/10 text-xs">
      <div class="max-w-7xl mx-auto px-4 py-1.5 flex justify-between items-center">
        <div class="flex gap-4 text-[color:var(--color-text-dark)] opacity-70">
          <a href="/coverage-map/" class="hover:opacity-100">Coverage Map</a>
          <span>|</span>
          <a href="/speedtest/" class="hover:opacity-100">Speedtest</a>
          <span>|</span>
          <a href="/about/mission/#contact" class="hover:opacity-100">Contact</a>
        </div>
        <div class="flex gap-2 font-mono">
          {LOCALES.map((loc) => (
            <a
              href={getLocalePath(loc)}
              class:list={[
                'hover:text-[color:var(--color-accent)] transition-colors',
                lang === loc
                  ? 'text-[color:var(--color-accent)]'
                  : 'opacity-50 hover:opacity-100',
              ]}
            >
              {LOCALE_LABELS[loc]}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Main nav -->
    <header class="border-b border-white/10">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="font-headline text-xl tracking-tight" style="font-weight:510;letter-spacing:-0.02em">
          Internet in <span class="text-[color:var(--color-accent)]">Myanmar</span>
        </a>
        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-6 text-sm">
          <nav class="flex gap-6">
            {nav.map((item) => (
              <div class="relative group">
                {item.href ? (
                  <a href={item.href} class="hover:text-[color:var(--color-accent)] transition-colors">
                    {item.label}
                  </a>
                ) : (
                  <>
                    <button class="hover:text-[color:var(--color-accent)] transition-colors cursor-default">
                      {item.label} ▾
                    </button>
                    <div class="absolute top-full left-0 pt-2 hidden group-hover:block z-50">
                      <div class="bg-[#0f1011] border border-white/10 rounded shadow-xl min-w-48 py-1">
                        {item.children?.map((child) => (
                          <a
                            href={child.href}
                            class="block px-4 py-2 text-sm hover:bg-white/5 hover:text-[color:var(--color-accent)]"
                          >
                            {child.label}
                          </a>
                        ))}
                      </div>
                    </div>
                  </>
                )}
              </div>
            ))}
          </nav>
          <button id="search-trigger"
            class="font-mono text-xs px-3 py-1.5 border border-white/20 rounded hover:border-white/50 flex items-center gap-2 transition-colors opacity-70 hover:opacity-100"
            aria-label="Search articles"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            Search
          </button>
        </div>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
          <span class="block w-5 h-0.5 bg-current"></span>
          <span class="block w-5 h-0.5 bg-current"></span>
          <span class="block w-5 h-0.5 bg-current"></span>
        </button>
      </div>

      <!-- Mobile menu drawer -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 px-4 py-4">
        <nav class="flex flex-col gap-1 text-sm">
          {nav.map((item) => (
            <div>
              {item.href ? (
                <a href={item.href} class="block py-2 hover:text-[color:var(--color-accent)]">
                  {item.label}
                </a>
              ) : (
                <details class="group">
                  <summary class="py-2 cursor-pointer hover:text-[color:var(--color-accent)] list-none flex justify-between items-center">
                    {item.label}
                    <span class="opacity-50">▾</span>
                  </summary>
                  <div class="pl-3 border-l border-white/10 mt-1 mb-2 flex flex-col gap-1">
                    {item.children?.map((child) => (
                      <a href={child.href} class="py-1.5 hover:text-[color:var(--color-accent)]">
                        {child.label}
                      </a>
                    ))}
                  </div>
                </details>
              )}
            </div>
          ))}
        </nav>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/10 mt-16">
      <div class="max-w-7xl mx-auto px-4 py-10 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm opacity-70">
        <div>
          <div class="font-headline text-base font-bold mb-2">Internet in Myanmar</div>
          <p>Independent technical monitor of Myanmar's digital environment. Tracking censorship, shutdowns, and connectivity.</p>
        </div>
        <div>
          <div class="font-semibold mb-2">Data sources</div>
          <ul class="space-y-1">
            <li><a href="https://ooni.org" class="hover:opacity-100" target="_blank" rel="noopener">OONI Explorer</a></li>
            <li><a href="https://radar.cloudflare.com" class="hover:opacity-100" target="_blank" rel="noopener">Cloudflare Radar</a></li>
            <li><a href="https://netblocks.org" class="hover:opacity-100" target="_blank" rel="noopener">NetBlocks</a></li>
          </ul>
        </div>
        <div>
          <div class="font-semibold mb-2">Editorial</div>
          <ul class="space-y-1">
            <li><a href="/about/mission/" class="hover:opacity-100">Mission</a></li>
            <li><a href="/about/sacha-nakeo/" class="hover:opacity-100">Sacha Nakeo</a></li>
            <li><a href="/rss.xml" class="hover:opacity-100">RSS Feed</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 text-center text-xs py-3 opacity-40">
        © {new Date().getFullYear()} Internet in Myanmar. Content licensed CC BY 4.0.
      </div>
    </footer>

    <!-- Search overlay -->
    <div id="search-overlay" class="fixed inset-0 z-50 hidden bg-black/80 backdrop-blur-sm p-4 md:p-20">
      <div class="max-w-2xl mx-auto bg-[#0f1011] border border-white/10 rounded-xl p-6">
        <div class="flex justify-between items-center mb-4">
          <span class="font-mono text-xs opacity-50">Search articles</span>
          <button id="search-close" class="opacity-50 hover:opacity-100 text-xl leading-none" aria-label="Close search">✕</button>
        </div>
        <input
          id="search-input"
          type="search"
          placeholder="Search articles…"
          class="w-full bg-white/5 border border-white/20 rounded px-4 py-3 text-sm font-mono placeholder-white/30 focus:outline-none focus:border-[color:var(--color-accent)] mb-4"
          autocomplete="off"
        />
        <div id="search-results" class="max-h-96 overflow-y-auto space-y-2"></div>
      </div>
    </div>
    <script>
      type Article = {
        slug: string
        title: string
        excerpt: string
        categories: string[]
        tags: string[]
        publishedAt: string
        type: string
        href: string
      }

      const overlay   = document.getElementById('search-overlay')!
      const trigger   = document.getElementById('search-trigger')!
      const closeBtn  = document.getElementById('search-close')!
      const input     = document.getElementById('search-input') as HTMLInputElement
      const resultsEl = document.getElementById('search-results')!

      let fuse: import('fuse.js').default<Article> | null = null

      async function initSearch() {
        if (fuse) return
        const [{ default: Fuse }, res] = await Promise.all([
          import('fuse.js'),
          fetch('/api/search-index.json'),
        ])
        const articles: Article[] = await res.json()
        fuse = new Fuse(articles, {
          keys: [
            { name: 'title',      weight: 0.5 },
            { name: 'excerpt',    weight: 0.3 },
            { name: 'tags',       weight: 0.15 },
            { name: 'categories', weight: 0.05 },
          ],
          threshold: 0.35,
          minMatchCharLength: 2,
        })
      }

      function renderResults(query: string) {
        if (!fuse || !query.trim()) {
          resultsEl.innerHTML = ''
          return
        }
        const hits = fuse.search(query, { limit: 8 })
        if (!hits.length) {
          resultsEl.innerHTML = '<p class="text-sm opacity-40 font-mono py-2">No results found.</p>'
          return
        }
        resultsEl.innerHTML = hits.map(({ item }) => `
          <a href="${item.href}"
             class="block px-4 py-3 rounded border border-white/5 hover:border-white/20 hover:bg-white/3 transition-colors">
            <div class="font-mono text-xs text-[color:var(--color-accent)] mb-1">${item.categories[0] ?? ''}${item.type === 'digest' ? ' · Digest' : ''}</div>
            <div class="text-sm font-semibold leading-snug mb-1">${item.title}</div>
            ${item.excerpt ? `<div class="text-xs opacity-50 line-clamp-1">${item.excerpt}</div>` : ''}
          </a>
        `).join('')
      }

      function openSearch() {
        overlay.classList.remove('hidden')
        input.focus()
        initSearch()
      }

      trigger.addEventListener('click', openSearch)
      closeBtn.addEventListener('click', () => overlay.classList.add('hidden'))
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') overlay.classList.add('hidden')
        if ((e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey)) {
          e.preventDefault()
          openSearch()
        }
      })
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) overlay.classList.add('hidden')
      })
      input.addEventListener('input', () => renderResults(input.value))

      // Mobile menu toggle
      const mobileToggle = document.getElementById('mobile-menu-toggle')
      const mobileMenu   = document.getElementById('mobile-menu')
      mobileToggle?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden')
      })
    </script>

  </body>
</html>
