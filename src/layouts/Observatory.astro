---
import Base from './Base.astro'

interface Props {
  title: string
  seoTitle: string
  metaDescription: string
  lastUpdated?: string
  dataSource?: string
  datasetName?: string
  datasetDescription?: string
  pageUrl?: string
}

const {
  title,
  seoTitle,
  metaDescription,
  lastUpdated,
  dataSource = 'OONI Explorer, Cloudflare Radar',
  datasetName,
  datasetDescription,
  pageUrl,
} = Astro.props

const siteUrl = 'https://www.internetinmyanmar.com'

const datasetSchema = datasetName ? {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: datasetName,
  description: datasetDescription ?? metaDescription,
  url: pageUrl ?? Astro.url.href,
  creator: { '@type': 'Organization', name: 'Internet in Myanmar', url: siteUrl },
  publisher: { '@type': 'Organization', name: 'Internet in Myanmar', url: siteUrl },
  temporalCoverage: '2021/..',
  spatialCoverage: { '@type': 'Place', name: 'Myanmar' },
  license: 'https://creativecommons.org/licenses/by/4.0/',
  isAccessibleForFree: true,
  keywords: ['Myanmar', 'internet shutdown', 'censorship', 'BGP', 'network monitoring'],
} : null
---
<Base {title} {seoTitle} {metaDescription}>
  {datasetSchema && <script type="application/ld+json" set:html={JSON.stringify(datasetSchema)} />}
  <!-- Live data banner -->
  <div class="border-b border-[color:var(--color-accent)]/30 bg-[color:var(--color-accent)]/5">
    <div class="max-w-7xl mx-auto px-4 py-2 flex items-center justify-between text-xs font-mono">
      <span class="flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span>
        <span class="text-[color:var(--color-accent)] font-semibold">LIVE DATA</span>
      </span>
      <span class="opacity-50">
        {lastUpdated
          ? `Updated ${new Date(lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} at ${new Date(lastUpdated).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC', hour12: false })} UTC`
          : 'Auto-updated twice daily'}
        · Source: {dataSource}
      </span>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-10">
    <h1 class="font-headline text-3xl md:text-4xl mb-2">{title}</h1>
    <slot />
  </div>
</Base>
